{%- comment -%} theme-check-disable RemoteAsset {%- endcomment -%}
<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;700&display=swap" rel="stylesheet">
{%- comment -%} theme-check-enable RemoteAsset {%- endcomment -%}

{%- style -%}
  .dji-header { background: {{ section.settings.bg_color }}; border-bottom: 1px solid #eee; direction: rtl; font-family: 'Heebo', sans-serif; position: relative; z-index: 1000; }
  .dji-header__container { display: flex; align-items: center; justify-content: space-between; max-width: 1400px; margin: 0 auto; padding: 0 20px; height: 70px; }
  .dji-header__nav { display: flex; gap: 30px; align-items: center; height: 100%; }
  .dji-nav__link { text-decoration: none; color: #000; font-weight: 500; font-size: 15px; cursor: pointer; height: 100%; display: flex; align-items: center; }
  
  .dji-mega-wrapper { position: relative; height: 100%; display: flex; align-items: center; }
  .dji-mega-menu { 
    position: absolute; top: 70px; right: -100px; width: 100vw; background: white; 
    box-shadow: 0 10px 30px rgba(0,0,0,0.1); opacity: 0; visibility: hidden; 
    transition: 0.3s ease; z-index: 1100; padding: 40px 0; border-top: 1px solid #eee;
  }
  .dji-mega-wrapper:hover .dji-mega-menu { opacity: 1; visibility: visible; }
  .dji-mega-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); max-width: 1200px; margin: 0 auto; gap: 25px; padding: 0 20px; }
  .dji-mega-item { text-align: center; text-decoration: none; color: #000; transition: 0.3s; }
  .dji-mega-item:hover { transform: translateY(-5px); }
  .dji-mega-item img { width: 70px; height: 70px; object-fit: contain; margin-bottom: 12px; background: #f9f9f9; border-radius: 50%; padding: 10px; }
  
  .dji-logo-img { max-height: 45px; width: auto; }
{%- endstyle -%}

<header class="dji-header">
  <div class="dji-header__container">
    <a href="/" class="dji-logo">
      {% if section.settings.logo != blank %}
        <img src="{{ section.settings.logo | image_url: width: 300 }}" class="dji-logo-img" alt="Logo">
      {% else %}
        <span style="font-weight:700; font-size:22px;">{{ shop.name }}</span>
      {% endif %}
    </a>
    
    <nav class="dji-header__nav">
      <div class="dji-mega-wrapper">
        <span class="dji-nav__link">{{ section.settings.mega_title }}</span>
        <div class="dji-mega-menu">
          <div class="dji-mega-grid">
            {%- for block in section.blocks -%}
              <a href="{{ block.settings.link }}" class="dji-mega-item" {{ block.shopify_attributes }}>
                {% if block.settings.image != blank %}
                  <img src="{{ block.settings.image | image_url: width: 200 }}" width="70" height="70" loading="lazy">
                {% else %}
                  <div style="width:70px; height:70px; background:#eee; border-radius:50%; margin:0 auto 12px;"></div>
                {% endif %}
                <div style="font-weight:700; font-size:16px;">{{ block.settings.title }}</div>
                <div style="font-size:12px; color:#666;">{{ block.settings.subtitle }}</div>
              </a>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </nav>

    <div class="dji-icons" style="display:flex; gap:20px;">
       <span style="cursor:pointer">🔍</span> <span style="cursor:pointer">🛒</span>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "DJI Mega Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "text", "id": "mega_title", "label": "Menu Title", "default": "רחפנים מקצועיים" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Icon" },
        { "type": "text", "id": "title", "label": "Title", "default": "חקלאות" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "פתרונות ריסוס" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    { "name": "DJI Mega Header" }
  ]
}
{% endschema %}