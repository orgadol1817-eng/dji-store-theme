    { "type": "text", "id": "main_headline", "label": "כותרת ראשית", "default": "לכידה רב-כיוונית, יעילות מוכפלת" },
    { "type": "range", "id": "main_headline_size", "min": 20, "max": 80, "step": 1, "unit": "px", "label": "גודל כותרת", "default": 48 },
