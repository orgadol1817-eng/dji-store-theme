{%- comment -%} theme-check-disable RemoteAsset {%- endcomment -%}
<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;700&display=swap" rel="stylesheet">
{%- comment -%} theme-check-enable RemoteAsset {%- endcomment -%}

{%- style -%}
  #DjiHeroSlider-{{ section.id }} {
    font-family: 'Heebo', sans-serif !important;
  }

  /* חישוב אטימות לרקע של חיצי הניווט (צדדים) */
  {%- assign arrow_alpha = section.settings.arrow_bg_opacity | divided_by: 100.0 -%}
  {%- assign arrow_bg_rgba = section.settings.arrow_bg_color | color_modify: 'alpha', arrow_alpha -%}

  #DjiHeroSlider-{{ section.id }} .dji-hero-slider__arrow {
    color: {{ section.settings.arrow_icon_color }} !important;
    background-color: {{ arrow_bg_rgba }} !important;
    border: {{ section.settings.arrow_border_width }}px solid {{ section.settings.arrow_border_color }} !important;
  }

  /* כפתורים ראשיים - צבעים ומיקומים לשקופיות */
  {%- for block in section.blocks -%}
    {%- assign alpha_1 = block.settings.bg_opacity_1 | divided_by: 100.0 -%}
    {%- assign bg_1_rgba = block.settings.bg_color_1 | color_modify: 'alpha', alpha_1 -%}
    
    {%- assign alpha_2 = block.settings.bg_opacity_2 | divided_by: 100.0 -%}
    {%- assign bg_2_rgba = block.settings.bg_color_2 | color_modify: 'alpha', alpha_2 -%}

    #DjiHeroSlider-{{ section.id }} [data-index="{{ forloop.index0 }}"] .dji-btn--primary {
      color: {{ block.settings.text_color_1 }} !important;
      background-color: {{ bg_1_rgba }} !important;
      border: 1px solid {{ block.settings.border_color_1 }} !important;
    }
    #DjiHeroSlider-{{ section.id }} [data-index="{{ forloop.index0 }}"] .dji-btn--secondary {
      color: {{ block.settings.text_color_2 }} !important;
      background-color: {{ bg_2_rgba }} !important;
      border: 1px solid {{ block.settings.border_color_2 }} !important;
    }
    
    #DjiHeroSlider-{{ section.id }} [data-index="{{ forloop.index0 }}"] .dji-btn--primary:hover {
      background-color: {{ block.settings.text_color_1 }} !important;
      color: #000 !important; 
      border-color: {{ block.settings.text_color_1 }} !important;
    }
    #DjiHeroSlider-{{ section.id }} [data-index="{{ forloop.index0 }}"] .dji-btn--secondary:hover {
      background-color: {{ block.settings.text_color_2 }} !important;
      color: #000 !important;
      border-color: {{ block.settings.text_color_2 }} !important;
    }

    #DjiHeroSlider-{{ section.id }} [data-index="{{ forloop.index0 }}"] .dji-hero-slider__img {
      object-position: {{ block.settings.image_pos_x }}% {{ block.settings.image_pos_y }}% !important;
      transform: scale({{ block.settings.image_zoom | divided_by: 100.0 }}) !important;
    }
  {%- endfor -%}
{%- endstyle -%}

{% stylesheet %}
.dji-hero-slider {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #000;
  direction: ltr;
  margin-left: calc(-50vw + 50%);
}

.dji-hero-slider__track { position: relative; width: 100%; height: 100%; }

.dji-hero-slider__slide {
  position: absolute; inset: 0; opacity: 0; visibility: hidden;
  transition: opacity 1s cubic-bezier(0.4, 0, 0.2, 1), visibility 0s linear 1s;
  pointer-events: none;
  overflow: hidden;
}

.dji-hero-slider__slide.is-active {
  opacity: 1; visibility: visible;
  transition: opacity 1s cubic-bezier(0.4, 0, 0.2, 1), visibility 0s linear 0s;
  pointer-events: auto; z-index: 1;
}

.dji-hero-slider__picture {
  position: absolute; inset: 0; width: 100%; height: 100%; display: block;
}

.dji-hero-slider__img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform 0.3s ease, object-position 0.3s ease;
}

.dji-hero-slider__placeholder {
  position: absolute; inset: 0; background: linear-gradient(135deg, #111 0%, #222 100%);
}

.dji-hero-slider__slide::after {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.45) 0%, rgba(0, 0, 0, 0.1) 55%, transparent 100%);
  z-index: 0; pointer-events: none;
}

.dji-hero-slider__content {
  position: absolute; top: 18%; left: 50%; transform: translateX(-50%);
  text-align: center; color: #fff; z-index: 2; width: min(820px, 90%);
  direction: rtl; 
}

.dji-hero-slider__title {
  font-size: clamp(2rem, 5vw, 4rem); font-weight: 700; line-height: 1.05;
  margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0px;
}

.dji-hero-slider__subtitle {
  font-size: clamp(0.9rem, 1.5vw, 1.15rem); font-weight: 300; margin-bottom: 1.75rem;
  opacity: 0.88; max-width: 580px; margin-inline: auto; line-height: 1.5;
}

.dji-hero-slider__btn-wrap {
  display: flex; gap: 20px; justify-content: center; flex-wrap: wrap;
}

.dji-btn--primary, .dji-btn--secondary {
  display: inline-flex; align-items: center; gap: 8px; text-decoration: none;
  transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
  padding: 8px 24px; border-radius: 30px; font-size: 15px; font-weight: 500;
  box-sizing: border-box; backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
}

.dji-arrow-double {
  display: inline-flex; align-items: center; justify-content: center;
  transition: transform 0.3s ease; width: 16px; height: 16px; flex-shrink: 0;
}

.dji-btn--primary:hover .dji-arrow-double, .dji-btn--secondary:hover .dji-arrow-double {
  transform: translateX(-5px); 
}

/* =========================================
   חיצי סליידר (צדדים) - עיצוב חדש ומתקדם
   ========================================= */
.dji-hero-slider__arrow {
  position: absolute; top: 50%; transform: translateY(-50%); z-index: 10;
  cursor: pointer; padding: 0;
  display: flex; align-items: center; justify-content: center;
  width: 44px; height: 44px; border-radius: 50%; 
  backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); 
  opacity: 0; transition: all 0.3s ease;
}

.dji-hero-slider:hover .dji-hero-slider__arrow { opacity: 0.8; }
.dji-hero-slider__arrow:hover { opacity: 1 !important; transform: translateY(-50%) scale(1.08); } 

.dji-hero-slider__arrow--prev { right: 20px; } 
.dji-hero-slider__arrow--next { left: 20px; }  

.dji-hero-slider__dots {
  position: absolute; bottom: 26px; left: 50%; transform: translateX(-50%);
  display: flex; gap: 10px; z-index: 10; direction: ltr; 
}
.dji-hero-slider__dot {
  width: 6px; height: 6px; border-radius: 50%; background: rgba(255, 255, 255, 0.35);
  border: none; cursor: pointer; padding: 0; transition: background 0.3s ease, transform 0.3s ease;
}
.dji-hero-slider__dot.is-active { background: #fff; transform: scale(1.5); }

@media (max-width: 768px) {
  .dji-hero-slider {
    width: 100%; margin-left: 0; height: auto;
    aspect-ratio: 3 / 4; min-height: 70vh; max-height: 85vh;
  }
  .dji-hero-slider__content { top: 10%; width: 100%; max-width: 100%; padding: 0 16px; box-sizing: border-box; }
  .dji-hero-slider__arrow { display: none; }
  .dji-hero-slider__title { font-size: clamp(1.7rem, 7.5vw, 2.6rem); }
  .dji-btn--primary, .dji-btn--secondary { padding: 7px 18px; font-size: 14px; }
}
{% endstylesheet %}

<div class="dji-hero-slider" id="DjiHeroSlider-{{ section.id }}" data-autoplay="{{ section.settings.autoplay_speed }}">
  <div class="dji-hero-slider__track">
    {%- for block in section.blocks -%}
      <div class="dji-hero-slider__slide{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
        
        {%- if block.settings.image != blank -%}
          <picture class="dji-hero-slider__picture">
            {%- if block.settings.image_mobile != blank -%}
              <source media="(max-width: 768px)" srcset="{{ block.settings.image_mobile | image_url: width: 1600 }}">
            {%- else -%}
              <source media="(max-width: 768px)" srcset="{{ block.settings.image | image_url: width: 1600 }}">
            {%- endif -%}
            <img src="{{ block.settings.image | image_url: width: 3200 }}" 
                 alt="{{ block.settings.title | escape }}" 
                 class="dji-hero-slider__img" 
                 width="{{ block.settings.image.width }}"
                 height="{{ block.settings.image.height }}"
                 loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
          </picture>
        {%- else -%}
          <div class="dji-hero-slider__placeholder"></div>
        {%- endif -%}

        <div class="dji-hero-slider__content">
          <h2 class="dji-hero-slider__title">{{ block.settings.title }}</h2>
          {%- if block.settings.subtitle != blank -%}
            <p class="dji-hero-slider__subtitle">{{ block.settings.subtitle }}</p>
          {%- endif -%}

          <div class="dji-hero-slider__btn-wrap">
            {%- if block.settings.link != blank and block.settings.button_label != blank -%}
              <a href="{{ block.settings.link }}" class="dji-btn--primary">
                <span>{{ block.settings.button_label }}</span>
                {% if block.settings.show_arrow_1 %}
                  <span class="dji-arrow-double">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M11 13L6 8L11 3"/><path d="M6 13L1 8L6 3"/>
                    </svg>
                  </span>
                {% endif %}
              </a>
            {%- endif -%}
            
            {%- if block.settings.secondary_link != blank and block.settings.secondary_label != blank -%}
              <a href="{{ block.settings.secondary_link }}" class="dji-btn--secondary">
                <span>{{ block.settings.secondary_label }}</span>
                {% if block.settings.show_arrow_2 %}
                  <span class="dji-arrow-double">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M11 13L6 8L11 3"/><path d="M6 13L1 8L6 3"/>
                    </svg>
                  </span>
                {% endif %}
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <button class="dji-hero-slider__arrow dji-hero-slider__arrow--prev">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    
    <button class="dji-hero-slider__arrow dji-hero-slider__arrow--next">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div class="dji-hero-slider__dots">
      {%- for block in section.blocks -%}
        <button class="dji-hero-slider__dot{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}"></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

<script>
(function () {
  var container = document.getElementById('DjiHeroSlider-{{ section.id }}');
  if (!container) return;
  var slides = container.querySelectorAll('.dji-hero-slider__slide');
  var dots   = container.querySelectorAll('.dji-hero-slider__dot');
  var current = 0; var total = slides.length;
  var speed = parseInt(container.dataset.autoplay, 10) || 5000;
  var timer; var touchStartX;

  function goTo(index) {
    slides[current].classList.remove('is-active');
    if (dots[current]) dots[current].classList.remove('is-active');
    current = (index + total) % total;
    slides[current].classList.add('is-active');
    if (dots[current]) dots[current].classList.add('is-active');
  }

  function next() { goTo(current + 1); }
  function prev() { goTo(current - 1); }
  function startTimer() { if (total > 1) timer = setInterval(next, speed); }
  function stopTimer()  { clearInterval(timer); }

  dots.forEach(function (dot) {
    dot.addEventListener('click', function () { stopTimer(); goTo(parseInt(dot.dataset.index, 10)); startTimer(); });
  });

  var bP = container.querySelector('.dji-hero-slider__arrow--prev');
  var bN = container.querySelector('.dji-hero-slider__arrow--next');
  if (bP) bP.addEventListener('click', function () { stopTimer(); next(); startTimer(); });
  if (bN) bN.addEventListener('click', function () { stopTimer(); prev(); startTimer(); });

  container.addEventListener('mouseenter', stopTimer);
  container.addEventListener('mouseleave', startTimer);
  container.addEventListener('touchstart', function (e) { touchStartX = e.touches[0].clientX; }, { passive: true });
  container.addEventListener('touchend', function (e) {
    var diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) { stopTimer(); if (diff > 0) { next(); } else { prev(); } startTimer(); }
  });
  startTimer();
})();
</script>

{% schema %}
{
  "name": "DJI Global Hero Slider",
  "max_blocks": 10,
  "settings": [
    { "type": "range", "id": "autoplay_speed", "min": 2000, "max": 9000, "step": 500, "unit": "ms", "label": "Autoplay speed", "default": 5000 },
    
    { "type": "header", "content": "Navigation Arrows (חיצי צדדים)" },
    { "type": "color", "id": "arrow_icon_color", "label": "צבע החץ", "default": "#ffffff" },
    { "type": "color", "id": "arrow_bg_color", "label": "צבע רקע לחצים", "default": "#ffffff" },
    { "type": "range", "id": "arrow_bg_opacity", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "אטימות רקע (0 = שקוף לגמרי)", "default": 10 },
    { "type": "color", "id": "arrow_border_color", "label": "צבע מסגרת", "default": "#ffffff" },
    { "type": "range", "id": "arrow_border_width", "min": 0, "max": 5, "step": 1, "unit": "px", "label": "עובי מסגרת", "default": 1 }
  ],
  "blocks": [
    {
      "type": "hero_slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Desktop image" },
        { "type": "image_picker", "id": "image_mobile", "label": "Mobile image (optional)" },
        
        { "type": "header", "content": "Image Adjustments (דיוק תמונה)" },
        { "type": "range", "id": "image_zoom", "min": 100, "max": 180, "step": 1, "unit": "%", "label": "זום (Zoom)", "default": 100 },
        { "type": "range", "id": "image_pos_x", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "מיקום אופקי (X - ימין/שמאל)", "default": 50 },
        { "type": "range", "id": "image_pos_y", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "מיקום אנכי (Y - למעלה/למטה)", "default": 50 },

        { "type": "text", "id": "title", "label": "Title", "default": "DJI PRODUCT" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Inspiration in Focus" },
        
        { "type": "header", "content": "Button 1 (קנה עכשיו)" },
        { "type": "text", "id": "button_label", "label": "טקסט הכפתור", "default": "קנה עכשיו" },
        { "type": "url", "id": "link", "label": "קישור" },
        { "type": "checkbox", "id": "show_arrow_1", "label": "הצג חץ כפול (>>)", "default": true },
        { "type": "color", "id": "text_color_1", "label": "צבע טקסט", "default": "#ffffff" },
        { "type": "color", "id": "bg_color_1", "label": "צבע רקע", "default": "#ffffff" },
        { "type": "range", "id": "bg_opacity_1", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "אטימות רקע", "default": 10 },
        { "type": "color", "id": "border_color_1", "label": "צבע מסגרת", "default": "#ffffff" },
        
        { "type": "header", "content": "Button 2 (סקירה מלאה)" },
        { "type": "text", "id": "secondary_label", "label": "טקסט הכפתור", "default": "סקירה מלאה" },
        { "type": "url", "id": "secondary_link", "label": "קישור" },
        { "type": "checkbox", "id": "show_arrow_2", "label": "הצג חץ כפול (>>)", "default": true },
        { "type": "color", "id": "text_color_2", "label": "צבע טקסט", "default": "#ffffff" },
        { "type": "color", "id": "bg_color_2", "label": "צבע רקע", "default": "#ffffff" },
        { "type": "range", "id": "bg_opacity_2", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "אטימות רקע", "default": 0 },
        { "type": "color", "id": "border_color_2", "label": "צבע מסגרת", "default": "#ffffff" }
      ]
    }
  ],
  "presets": [{ "name": "DJI Global Hero Slider" }]
}
{% endschema %}