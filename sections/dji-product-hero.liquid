{%- comment -%}
  DroX Product Hero - Full Cinematic Section for Matrice 4
{%- endcomment -%}

{%- style -%}
  .dji-hero-wrapper-{{ section.id }} {
    background-color: #000;
    margin: 0;
    padding: 0;
    width: 100%;
    overflow: hidden;
  }

  .dji-hero-{{ section.id }} {
    color: #fff;
    width: 100%;
    min-height: {{ section.settings.hero_height }}vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    position: relative;
    padding-top: {{ section.settings.padding_top }}px;
    direction: rtl;
    font-family: 'Heebo', sans-serif;
  }

  .dji-hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .dji-hero-bg video, .dji-hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: {{ section.settings.overlay_opacity }};
  }

  .dji-hero-content {
    position: relative;
    z-index: 2;
    max-width: 1000px;
    padding: 0 20px;
  }

  .dji-hero-content h2 {
    font-size: clamp(16px, 2vw, 24px);
    font-weight: 300;
    color: #aaa;
    margin-bottom: 15px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .dji-hero-content h1 {
    font-size: clamp(40px, 8vw, 90px);
    font-weight: 800;
    margin: 0;
    line-height: 1.1;
    letter-spacing: -1px;
  }

  .dji-hero-content p {
    font-size: clamp(16px, 1.5vw, 22px);
    opacity: 0.8;
    margin-top: 25px;
    font-weight: 300;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 768px) {
    .dji-hero-{{ section.id }} {
      min-height: 60vh;
      padding-top: 40px;
    }
    .dji-hero-{{ section.id }} .dji-hero-content {
      padding: 0 16px;
      box-sizing: border-box;
    }
  }
{%- endstyle -%}

<div class="dji-hero-wrapper-{{ section.id }}">
  <section class="dji-hero-{{ section.id }}">
    <div class="dji-hero-bg">
      {% if section.settings.video_url != blank %}
        <video autoplay muted loop playsinline poster="{{ section.settings.image | image_url: width: 2000 }}">
          <source src="{{ section.settings.video_url }}" type="video/mp4">
        </video>
      {% elsif section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'lazy' }}
      {% else %}
        <div style="background: #111; width: 100%; height: 100%;"></div>
      {% endif %}
    </div>

    <div class="dji-hero-content">
      {% if section.settings.top_title != blank %}
        <h2>{{ section.settings.top_title }}</h2>
      {% endif %}
      
      <h1>{{ section.settings.main_title }}</h1>
      
      {% if section.settings.sub_text != blank %}
        <p>{{ section.settings.sub_text }}</p>
      {% endif %}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "DroX Product Hero",
  "settings": [
    {
      "type": "header",
      "content": "מדיה ורקע"
    },
    { "type": "text", "id": "video_url", "label": "קישור ישיר לוידאו (MP4)", "info": "העלה ל-Content > Files והדבק כאן" },
    { "type": "image_picker", "id": "image", "label": "תמונת גיבוי/רקע" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 1, "step": 0.1, "label": "בהירות ויזואלית", "default": 0.7 },
    {
      "type": "header",
      "content": "מידות וריווחים"
    },
    { "type": "range", "id": "hero_height", "min": 40, "max": 100, "step": 5, "unit": "vh", "label": "גובה הסקשן", "default": 90 },
    { "type": "number", "id": "padding_top", "label": "רווח מההדר (פיקסלים)", "default": 0 },
    {
      "type": "header",
      "content": "טקסטים"
    },
    { "type": "text", "id": "top_title", "label": "כותרת קטנה עליונה", "default": "רחפן הדגל הקומפקטי לתעשייה" },
    { "type": "text", "id": "main_title", "label": "כותרת ראשית", "default": "MATRICE 4" },
    { "type": "textarea", "id": "sub_text", "label": "טקסט תיאור", "default": "עידן חדש של טיסה חכמה מתחיל עכשיו. שילוב מושלם של עוצמה, בינה מלאכותית וניידות." }
  ],
  "presets": [
    {
      "name": "DroX Product Hero"
    }
  ]
}
{% endschema %}