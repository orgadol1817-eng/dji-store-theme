          "id": "subtitle",
          "label": "תת כותרת"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "צבע טקסט",
          "default": "#ffffff"
        },
        {
          "type": "header",
          "content": "עיצוב כפתורים (Buttons UI)"
        },
        {
          "type": "color",
          "id": "btn_bg_color",
          "label": "צבע רקע לכפתורים",
          "default": "#ffffff"
        },
        {
          "type": "range",
          "id": "btn_bg_opacity",
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "label": "אטימות רקע כפתור (100 = מלא, 0 = שקוף)",
          "default": 0
        },
        {
          "type": "color",
          "id": "btn_border_color",
          "label": "צבע מסגרת כפתור",
          "default": "#ffffff"
        },
        {
          "type": "header",
          "content": "כפתור 1"
        },
        {
          "type": "text",
          "id": "text_learn",
          "label": "טקסט",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "link_learn",
          "label": "קישור"
        },
        {
          "type": "checkbox",
          "id": "show_arrow_learn",
          "label": "הצג חץ כפול",
          "default": true
        },
        {
          "type": "header",
          "content": "כפתור 2"
