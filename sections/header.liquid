{%- if section.settings.show_top_bar -%}
  {%- liquid
    assign about_l = section.settings.about_link_label | strip
    assign terms_l = section.settings.terms_link_label | strip
    assign privacy_l = section.settings.privacy_link_label | strip
  -%}
  {% style %}
    #shopify-section-{{ section.id }} .drox-top-bar {
      background-color: {{ section.settings.top_bar_bg }};
      margin: 0;
      padding: 0;
    }
    #shopify-section-{{ section.id }} .drox-top-bar__inner {
      min-height: {{ section.settings.top_bar_height }}px;
      --drox-links-gap: {{ section.settings.top_bar_links_gap }}px;
    }
    #shopify-section-{{ section.id }} .drox-top-bar__link {
      color: {{ section.settings.top_bar_right_color }};
    }
    #shopify-section-{{ section.id }} .drox-top-bar__pipe {
      color: {{ section.settings.top_bar_right_color }};
    }
    #shopify-section-{{ section.id }} .drox-top-bar__promo {
      color: {{ section.settings.top_bar_middle_color }};
    }
    #shopify-section-{{ section.id }} .drox-top-bar__left-label {
      color: {{ section.settings.top_bar_left_label_color }};
    }
    #shopify-section-{{ section.id }} .drox-top-bar__phone-num {
      color: {{ section.settings.top_bar_phone_color }};
    }
    #shopify-section-{{ section.id }} .drox-top-bar__segment--right {
      transform: translateX({{ section.settings.right_segment_offset }}px);
    }
    #shopify-section-{{ section.id }} .drox-top-bar__segment--middle {
      transform: translateX({{ section.settings.middle_segment_offset }}px);
    }
    #shopify-section-{{ section.id }} .drox-top-bar__segment--left {
      transform: translateX({{ section.settings.left_segment_offset }}px);
    }
    @media (max-width: 767px) {
      #shopify-section-{{ section.id }} .drox-top-bar--suppress-mobile {
        display: none !important;
      }
      #shopify-section-{{ section.id }} .drox-top-bar__segment--hide-sm {
        display: none !important;
      }
      #shopify-section-{{ section.id }} .drox-top-bar {
        background-color: {{ section.settings.top_bar_bg_mobile }};
      }
      #shopify-section-{{ section.id }} .drox-top-bar .drox-top-bar__link,
      #shopify-section-{{ section.id }} .drox-top-bar .drox-top-bar__pipe,
      #shopify-section-{{ section.id }} .drox-top-bar .drox-top-bar__promo,
      #shopify-section-{{ section.id }} .drox-top-bar .drox-top-bar__contact-line,
      #shopify-section-{{ section.id }} .drox-top-bar .drox-top-bar__left-label,
      #shopify-section-{{ section.id }} .drox-top-bar .drox-top-bar__phone-num {
        font-size: {{ section.settings.top_bar_font_size_mobile }}px;
      }
    }
  {% endstyle %}
  <div class="drox-top-bar{% unless section.settings.show_top_bar_mobile %} drox-top-bar--suppress-mobile{% endunless %}" data-drox-top-bar>
    <div class="drox-top-bar__inner">
      <div class="drox-top-bar__col drox-top-bar__col--links drox-top-bar__segment drox-top-bar__segment--right{% if section.settings.hide_links_mobile %} drox-top-bar__segment--hide-sm{% endif %}">
        <div class="drox-top-bar__links-row">
          {%- if about_l != blank -%}
            {%- if section.settings.about_link != blank -%}
              <a class="drox-top-bar__link" href="{{ section.settings.about_link }}">{{ about_l }}</a>
            {%- else -%}
              <span class="drox-top-bar__link drox-top-bar__link--static">{{ about_l }}</span>
            {%- endif -%}
          {%- endif -%}
          {%- if terms_l != blank -%}
            {%- if about_l != blank -%}
              <span class="drox-top-bar__pipe" aria-hidden="true">|</span>
            {%- endif -%}
            {%- if section.settings.terms_link != blank -%}
              <a class="drox-top-bar__link" href="{{ section.settings.terms_link }}">{{ terms_l }}</a>
            {%- else -%}
              <span class="drox-top-bar__link drox-top-bar__link--static">{{ terms_l }}</span>
            {%- endif -%}
          {%- endif -%}
          {%- if privacy_l != blank -%}
            {%- if about_l != blank or terms_l != blank -%}
              <span class="drox-top-bar__pipe" aria-hidden="true">|</span>
            {%- endif -%}
            {%- if section.settings.privacy_link != blank -%}
              <a class="drox-top-bar__link" href="{{ section.settings.privacy_link }}">{{ privacy_l }}</a>
            {%- else -%}
              <span class="drox-top-bar__link drox-top-bar__link--static">{{ privacy_l }}</span>
            {%- endif -%}
          {%- endif -%}
        </div>
      </div>
      <div class="drox-top-bar__col drox-top-bar__col--promo drox-top-bar__segment drox-top-bar__segment--middle{% if section.settings.hide_promo_mobile %} drox-top-bar__segment--hide-sm{% endif %}">
        <span class="drox-top-bar__promo">{{ section.settings.promo_text }}</span>
      </div>
      <div class="drox-top-bar__col drox-top-bar__col--phone drox-top-bar__segment drox-top-bar__segment--left{% if section.settings.hide_phone_mobile %} drox-top-bar__segment--hide-sm{% endif %}">
        <span class="drox-top-bar__contact-line">
          <span class="drox-top-bar__left-label">{{ section.settings.left_contact_label }}</span><span class="drox-top-bar__phone-num">{{ section.settings.phone_number_text }}</span>
        </span>
      </div>
    </div>
  </div>
{%- endif -%}
{% style %}
  /* Reset white space bug */
  body, html { margin: 0; padding: 0; }
  #shopify-section-{{ section.id }} {
    margin-top: 0 !important;
    padding-top: 0 !important;
  }

  /* Visually hide accessibility links safely to prevent white gaps */
  .skip-to-content-link:not(:focus) {
    clip: rect(1px, 1px, 1px, 1px) !important;
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    overflow: hidden !important;
  }

  #shopify-section-{{ section.id }} {
    --sh-nav-color: {{ section.settings.nav_link_color }};
    --sh-nav-hover: {{ section.settings.nav_link_hover_color }};
    --sh-header-scrolled-bg: {{ section.settings.header_scrolled_bg }};
    --sh-header-scrolled-nav: {{ section.settings.header_scrolled_nav_color }};
    --sh-header-height: {{ section.settings.header_height }}px;

    /* Mega Menu Variables (User Controlled) */
    --sh-mega-bg: {{ section.settings.mega_panel_bg }};
    --sh-mega-title: {{ section.settings.mega_card_title_color }};
    --sh-mega-hover: {{ section.settings.mega_card_link_hover_color }};
    --sh-mega-font-size: {{ section.settings.mega_font_size }}px;
    --sh-mega-width: {{ section.settings.mega_panel_width }}px;
    --sh-mega-item-padding-v: {{ section.settings.mega_item_padding_v }}px;
    --sh-mega-border: {{ section.settings.mega_panel_border_color }};
    --sh-mega-bg-hover: {{ section.settings.mega_card_bg_hover_color }};

    --sh-license-badge-bg: {{ section.settings.license_badge_color }};
    --sh-license-badge-fg: {{ section.settings.license_badge_text_color }};
    --sh-drawer-bg: {{ section.settings.drawer_bg_color }};
    --sh-drawer-text: {{ section.settings.drawer_text_color }};
    --sh-drawer-accent: {{ section.settings.drawer_accent_color }};
  }
  
  /* --- BENDA STYLE FLAT MEGA MENU --- */
  
  /* הפאנל הראשי */
  #shopify-section-{{ section.id }} .sh-benda-panel {
    position: absolute;
    top: 100%;
    right: 0;
    width: var(--sh-mega-width);
    min-width: var(--sh-mega-width);
    max-width: var(--sh-mega-width);
    background: var(--sh-mega-bg);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    border: 1px solid var(--sh-mega-border);
    border-top: none;
    z-index: 9602;
    opacity: 0;
    visibility: hidden;
    direction: rtl;
    pointer-events: none;
  }
  
  #shopify-section-{{ section.id }} .sh-mega-wrap:hover .sh-benda-panel {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  
  /* רשימות */
  #shopify-section-{{ section.id }} .sh-benda-list {
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
  }
  
  #shopify-section-{{ section.id }} .sh-benda-item {
    position: relative;
    margin: 0;
    padding: 0;
    width: 100%;
  }
  
  /* הקישור — full row hit area, padding + font from Customizer */
  #shopify-section-{{ section.id }} .sh-benda-link {
    position: relative;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    width: 100%;
    min-height: calc(var(--sh-mega-item-padding-v) * 2 + var(--sh-mega-font-size) * 1.35);
    padding: var(--sh-mega-item-padding-v) 15px;
    color: var(--sh-mega-title);
    font-size: var(--sh-mega-font-size);
    font-weight: 400;
    text-decoration: none;
    transition: background-color 0.1s ease, color 0.1s ease;
  }
  
  /* צבע רקע במעבר עכבר - מילוי מלא! */
  #shopify-section-{{ section.id }} .sh-benda-link:hover, 
  #shopify-section-{{ section.id }} .sh-benda-item:hover > .sh-benda-link {
    background-color: var(--sh-mega-bg-hover);
    color: var(--sh-mega-hover);
  }
  
  /* החץ - נעול שמאלה כדי לא להפריע למרכוז */
  #shopify-section-{{ section.id }} .sh-benda-arrow {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    opacity: 0.4;
  }

  /* מגירות פנימיות - נצמדות באופן חלק בלי קופסאות */
  #shopify-section-{{ section.id }} .sh-benda-flyout {
    position: absolute;
    top: -1px;
    right: 100%;
    width: var(--sh-mega-width);
    min-width: var(--sh-mega-width);
    max-width: var(--sh-mega-width);
    background: var(--sh-mega-bg);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    border: 1px solid var(--sh-mega-border);
    border-right: none; 
    list-style: none;
    padding: 0;
    margin: 0;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    z-index: 10;
  }
  
  #shopify-section-{{ section.id }} .sh-benda-item:hover > .sh-benda-flyout {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  /* ---------------------------------------- */

  {%- if section.settings.logo_hover_enabled -%}
  /* Logo: tint pixels to nav hover color (transparent outside logo — no background box) */
  #shopify-section-{{ section.id }} .sh-logo {
    display: flex;
    width: {{ section.settings.logo_width }}px;
    max-width: 100%;
    max-height: 100%;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    padding: 0;
    border-radius: 0;
    background: transparent;
  }

  #shopify-section-{{ section.id }} .sh-logo:hover {
    background-color: transparent;
  }

  #shopify-section-{{ section.id }} .header__logo-img {
    width: 100%;
    max-width: 100%;
    max-height: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    transition: filter 0.25s ease;
  }

  #shopify-section-{{ section.id }} .sh-logo:hover .header__logo-img {
    filter: url(#logo-hover-tint-{{ section.id }});
  }
  {%- else -%}
  #shopify-section-{{ section.id }} .sh-logo {
    display: flex;
    width: {{ section.settings.logo_width }}px;
    max-width: 100%;
    max-height: 100%;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    padding: 0;
    border-radius: 0;
  }

  #shopify-section-{{ section.id }} .header__logo-img {
    width: 100%;
    max-width: 100%;
    max-height: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }
  {%- endif -%}
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .sh-logo {
      width: {{ section.settings.logo_width_mobile }}px;
    }
  }
  #shopify-section-{{ section.id }} .site-header {
    height: var(--sh-header-height);
    min-height: var(--sh-header-height);
    background: {{ section.settings.header_nav_bg }};
  }

  #shopify-section-{{ section.id }} .sh-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    min-height: 0;
  }
  #shopify-section-{{ section.id }} .site-header.scrolled {
    background: var(--sh-header-scrolled-bg);
  }
  #shopify-section-{{ section.id }} .site-header.scrolled .sh-nav__link,
  #shopify-section-{{ section.id }} .site-header.scrolled .sh-tool-btn {
    color: var(--sh-header-scrolled-nav);
  }
  #shopify-section-{{ section.id }} .sh-nav__link,
  #shopify-section-{{ section.id }} .sh-tool-btn {
    color: var(--sh-nav-color);
  }
  
  /* Hover effects for main nav links */
  #shopify-section-{{ section.id }} .sh-nav__link:hover {
    color: var(--sh-nav-hover);
    opacity: 1;
    {% if section.settings.nav_hover_bold %}
    text-shadow: 0 0 0.6px var(--sh-nav-hover);
    {% endif %}
  }
  #shopify-section-{{ section.id }} .sh-mega-wrap:hover .sh-nav__link--mega {
    color: var(--sh-nav-hover);
    {% if section.settings.nav_hover_bold %}
    text-shadow: 0 0 0.6px var(--sh-nav-hover);
    {% endif %}
  }

  #shopify-section-{{ section.id }} .sh-nav {
    gap: {{ section.settings.menu_item_spacing }}px;
  }
  #shopify-section-{{ section.id }} .sh-nav__badge {
    background: var(--sh-license-badge-bg);
    color: var(--sh-license-badge-fg);
  }
{% endstyle %}

{%- liquid
  # Extract unique Level 1 Categories from all blocks
  assign l1_raw = ""
  for block in section.blocks
    if block.type == 'mega_category'
      assign l1_title = block.settings.l1_title | strip
      if l1_title != blank
        assign delimiter = "@@" | append: l1_title | append: "@@"
        unless l1_raw contains delimiter
          assign l1_raw = l1_raw | append: delimiter | append: "||"
        endunless
      endif
    endif
  endfor
  assign l1_list = l1_raw | split: "||"
-%}

<header class="site-header{% if section.settings.show_top_bar %} site-header--has-top-bar{% endif %}" id="site-header">
  {%- if section.settings.logo_hover_enabled -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="0" height="0" class="sh-logo-hover-filter" style="position:absolute;overflow:hidden;pointer-events:none" aria-hidden="true" focusable="false">
      <defs>
        <filter id="logo-hover-tint-{{ section.id }}" color-interpolation-filters="sRGB" x="-20%" y="-20%" width="140%" height="140%">
          <feFlood flood-color="{{ section.settings.nav_link_hover_color }}" flood-opacity="1" result="flood"/>
          <feComposite in="flood" in2="SourceAlpha" operator="in" result="tinted"/>
        </filter>
      </defs>
    </svg>
  {%- endif -%}
  <div class="sh-inner">

    <a class="sh-logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      <img
        src="https://cdn.shopify.com/s/files/1/0758/4897/4509/files/logo_drox.png?v=1773919882"
        alt="DROX"
        class="header__logo-img"
        width="120"
        height="40"
        loading="eager"
      >
    </a>

    <nav class="sh-nav" aria-label="ניווט ראשי">
      
      <div class="sh-mega-wrap">
        <div class="sh-mega-trigger" id="sh-mega-trigger-catalog" aria-expanded="false">
          <span class="sh-nav__link sh-nav__link--mega">
            <span class="sh-nav__mega-text">{{ section.settings.nav_catalog_label }}</span>
            <svg class="sh-nav__mega-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </span>
        </div>
        
        <div class="sh-mega-panel sh-benda-panel" id="sh-mega-panel" role="region" aria-hidden="true">
          {%- if l1_list.size > 0 -%}
            <ul class="sh-benda-list" role="list">
              
              {%- for l1_item in l1_list -%}
                {%- if l1_item != blank -%}
                  {%- assign l1_name = l1_item | remove: "@@" -%}
                  
                  <li class="sh-benda-item">
                    <a href="#" class="sh-benda-link">
                      <span>{{ l1_name }}</span>
                      <svg class="sh-benda-arrow" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 18l-6-6 6-6"/>
                      </svg>
                    </a>

                    <ul class="sh-benda-flyout" role="list">
                      {%- for block in section.blocks -%}
                        {%- if block.type == 'mega_category' and block.settings.l1_title == l1_name -%}
                          
                          {%- if block.settings.l2_title != blank -%}
                            <li class="sh-benda-item" {{ block.shopify_attributes }}>
                              <a href="{{ block.settings.l2_link | default: '#' }}" class="sh-benda-link">
                                <span>{{ block.settings.l2_title }}</span>
                                {%- if block.settings.link_1_text != blank -%}
                                  <svg class="sh-benda-arrow" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M15 18l-6-6 6-6"/>
                                  </svg>
                                {%- endif -%}
                              </a>

                              {%- if block.settings.link_1_text != blank -%}
                                <ul class="sh-benda-flyout" role="list">
                                  {%- if block.settings.link_1_text != blank -%}<li><a href="{{ block.settings.link_1_url | default: '#' }}" class="sh-benda-link"><span>{{ block.settings.link_1_text }}</span></a></li>{%- endif -%}
                                  {%- if block.settings.link_2_text != blank -%}<li><a href="{{ block.settings.link_2_url | default: '#' }}" class="sh-benda-link"><span>{{ block.settings.link_2_text }}</span></a></li>{%- endif -%}
                                  {%- if block.settings.link_3_text != blank -%}<li><a href="{{ block.settings.link_3_url | default: '#' }}" class="sh-benda-link"><span>{{ block.settings.link_3_text }}</span></a></li>{%- endif -%}
                                  {%- if block.settings.link_4_text != blank -%}<li><a href="{{ block.settings.link_4_url | default: '#' }}" class="sh-benda-link"><span>{{ block.settings.link_4_text }}</span></a></li>{%- endif -%}
                                  {%- if block.settings.link_5_text != blank -%}<li><a href="{{ block.settings.link_5_url | default: '#' }}" class="sh-benda-link"><span>{{ block.settings.link_5_text }}</span></a></li>{%- endif -%}
                                  {%- if block.settings.link_6_text != blank -%}<li><a href="{{ block.settings.link_6_url | default: '#' }}" class="sh-benda-link"><span>{{ block.settings.link_6_text }}</span></a></li>{%- endif -%}
                                  {%- if block.settings.link_7_text != blank -%}<li><a href="{{ block.settings.link_7_url | default: '#' }}" class="sh-benda-link"><span>{{ block.settings.link_7_text }}</span></a></li>{%- endif -%}
                                  {%- if block.settings.link_8_text != blank -%}<li><a href="{{ block.settings.link_8_url | default: '#' }}" class="sh-benda-link"><span>{{ block.settings.link_8_text }}</span></a></li>{%- endif -%}
                                </ul>
                              {%- endif -%}
                            </li>
                          {%- else -%}
                            {%- if block.settings.link_1_text != blank -%}<li class="sh-benda-item" {{ block.shopify_attributes }}><a href="{{ block.settings.link_1_url | default: '#' }}" class="sh-benda-link"><span>{{ block.settings.link_1_text }}</span></a></li>{%- endif -%}
                            {%- if block.settings.link_2_text != blank -%}<li class="sh-benda-item"><a href="{{ block.settings.link_2_url | default: '#' }}" class="sh-benda-link"><span>{{ block.settings.link_2_text }}</span></a></li>{%- endif -%}
                            {%- if block.settings.link_3_text != blank -%}<li class="sh-benda-item"><a href="{{ block.settings.link_3_url | default: '#' }}" class="sh-benda-link"><span>{{ block.settings.link_3_text }}</span></a></li>{%- endif -%}
                            {%- if block.settings.link_4_text != blank -%}<li class="sh-benda-item"><a href="{{ block.settings.link_4_url | default: '#' }}" class="sh-benda-link"><span>{{ block.settings.link_4_text }}</span></a></li>{%- endif -%}
                            {%- if block.settings.link_5_text != blank -%}<li class="sh-benda-item"><a href="{{ block.settings.link_5_url | default: '#' }}" class="sh-benda-link"><span>{{ block.settings.link_5_text }}</span></a></li>{%- endif -%}
                            {%- if block.settings.link_6_text != blank -%}<li class="sh-benda-item"><a href="{{ block.settings.link_6_url | default: '#' }}" class="sh-benda-link"><span>{{ block.settings.link_6_text }}</span></a></li>{%- endif -%}
                            {%- if block.settings.link_7_text != blank -%}<li class="sh-benda-item"><a href="{{ block.settings.link_7_url | default: '#' }}" class="sh-benda-link"><span>{{ block.settings.link_7_text }}</span></a></li>{%- endif -%}
                            {%- if block.settings.link_8_text != blank -%}<li class="sh-benda-item"><a href="{{ block.settings.link_8_url | default: '#' }}" class="sh-benda-link"><span>{{ block.settings.link_8_text }}</span></a></li>{%- endif -%}
                          {%- endif -%}
                          
                        {%- endif -%}
                      {%- endfor -%}
                    </ul>

                  </li>
                {%- endif -%}
              {%- endfor -%}
              
            </ul>
          {%- else -%}
            <div style="padding: 15px; color: #666; font-size: 13px;">הוסף בלוקים מסוג "קבוצת רחפנים" בעורך.</div>
          {%- endif -%}
        </div>
      </div>

      <div class="sh-nav__item sh-nav__item--license">
        <a class="sh-nav__link sh-nav__link--license" href="{{ section.settings.nav_license_url | default: '#' }}">
          {%- if section.settings.show_license_badge -%}
            <span class="sh-nav__badge" aria-hidden="true">{{ section.settings.license_badge_text }}</span>
          {%- endif -%}
          <span class="sh-nav__license-text">{{ section.settings.nav_license_label }}</span>
        </a>
      </div>
      <a class="sh-nav__link" href="{{ section.settings.nav_about_url | default: '#' }}">{{ section.settings.nav_about_label }}</a>
