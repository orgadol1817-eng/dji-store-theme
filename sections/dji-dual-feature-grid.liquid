        { "type": "range", "id": "media_zoom", "min": 100, "max": 200, "step": 1, "unit": "%", "label": "זום פנימי", "default": 100 },
        { "type": "range", "id": "focal_x", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "מיקוד X", "default": 50 },
        { "type": "range", "id": "focal_y", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "מיקוד Y", "default": 50 },
        { "type": "range", "id": "media_margin_bottom", "min": 0, "max": 60, "step": 1, "unit": "px", "label": "רווח מתחת למדיה", "default": 25 },
        { "type": "header", "content": "📝 תוכן" },
        { "type": "text", "id": "title", "label": "כותרת", "default": "כותרת טכנולוגית" },
