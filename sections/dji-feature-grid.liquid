{%- comment -%}
  DJI Feature Bento Grid - v1.2 (Black Border Edition)
  - השארתי את התבניות והסדר בדיוק כמו שאהבת ב-v1.1
  - הוספתי סליידרים לשליטה ברווח השחור למעלה ולמטה (Padding)
  - שליטה אנכית (Offset) וצבעי טקסט נשמרו
{%- endcomment -%}

{%- style -%}
  .dji-bento-{{ section.id }} {
    background-color: #000;
    /* שליטה בהזזה של כל הסקשן */
    margin-top: {{ section.settings.vertical_offset }}px;
    /* שליטה בגבולות השחורים למעלה ולמטה */
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: 4%;
    padding-right: 4%;
    font-family: 'Heebo', sans-serif;
    direction: rtl;
    position: relative;
    z-index: 5;
  }

  .dji-bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 320px;
    gap: 15px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .dji-bento-card {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    background-color: #161616;
    display: flex;
    transition: transform 0.4s ease;
  }

  .card-wide { grid-column: span 2; }
  .card-standard { grid-column: span 1; }

  .dji-bento-card:hover .card-bg-media {
    transform: scale(1.05);
  }

  .card-bg-media {
    position: absolute;
    inset: 0;
    z-index: 1;
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .card-bg-media img, .card-bg-media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(180deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0) 40%, rgba(0,0,0,0.5) 100%);
  }

  .card-info {
    position: absolute;
    z-index: 3;
    padding: 30px;
    width: 100%;
    pointer-events: none;
    box-sizing: border-box;
  }

  .card-title {
    font-size: 24px;
    font-weight: 600;
    margin: 0;
    text-shadow: 0 2px 10px rgba(0,0,0,0.5);
    letter-spacing: -0.5px;
  }

  .card-arrow {
    position: absolute;
    bottom: 20px;
    right: 20px;
    z-index: 4;
    width: 24px;
    height: 24px;
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
  }

  @media (max-width: 990px) {
    .dji-bento-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 280px;
    }
    .card-wide { grid-column: span 1; }
    .dji-bento-{{ section.id }} { 
      margin-top: 0; 
      padding-top: 40px; 
      padding-bottom: 40px; 
    }
  }

  @media (max-width: 768px) {
    .dji-bento-{{ section.id }} {
      padding-left: 16px;
      padding-right: 16px;
      padding-top: {{ section.settings.padding_top | times: 0.55 | round }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.55 | round }}px;
    }

    .dji-bento-{{ section.id }} .dji-bento-grid {
      gap: 10px;
      grid-auto-rows: 220px;
    }

    .dji-bento-{{ section.id }} .card-info {
      padding: 16px;
    }

    .dji-bento-{{ section.id }} .card-title {
      font-size: 18px;
    }

    .dji-bento-{{ section.id }} .card-arrow {
      bottom: 14px;
      right: 14px;
      width: 22px;
      height: 22px;
    }
  }
{%- endstyle -%}

<section class="dji-bento-{{ section.id }}">
  <div class="dji-bento-grid">
    
    {%- for block in section.blocks -%}
      <div class="dji-bento-card {{ block.settings.card_size }}" {{ block.shopify_attributes }}>
        
        <div class="card-bg-media">
          {%- if block.settings.video_url != blank -%}
            <video autoplay muted loop playsinline poster="{{ block.settings.image | image_url }}">
              <source src="{{ block.settings.video_url | escape }}" type="video/mp4">
            </video>
          {%- elsif block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
          {%- endif -%}
        </div>

        <div class="card-overlay"></div>

        <div class="card-info" style="
          top: {{ block.settings.y_pos }}%; 
          left: {{ block.settings.x_pos }}%; 
          transform: translate(-{{ block.settings.x_pos }}%, -{{ block.settings.y_pos }}%); 
          text-align: {{ block.settings.text_align }};">
          
          <h3 class="card-title" style="color: {{ block.settings.text_color }};">
            {{ block.settings.title }}
          </h3>
        </div>

        <div class="card-arrow">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M7 13l5 5 5-5M7 6l5 5 5-5"/>
          </svg>
        </div>

      </div>
    {%- endfor -%}

  </div>
</section>

{% schema %}
{
  "name": "DJI Feature Bento Grid",
  "settings": [
    {
      "type": "header",
      "content": "גבולות ומרחקים (Black Borders)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "רווח עליון (שחור)",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "רווח תחתוו (שחור)",
      "default": 100
    },
    {
      "type": "range",
      "id": "vertical_offset",
      "min": -200,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "הזזה אנכית של כל הסקשן",
      "default": 0,
      "info": "ערך שלילי יעלה את הסקשן למעלה"
    }
  ],
  "blocks": [
    {
      "type": "feature_card",
      "name": "כרטיס תכונה",
      "settings": [
        { "type": "text", "id": "title", "label": "כותרת", "default": "כותרת תכונה" },
        { "type": "color", "id": "text_color", "label": "צבע טקסט", "default": "#ffffff" },
        { "type": "image_picker", "id": "image", "label": "תמונת רקע" },
        { "type": "text", "id": "video_url", "label": "וידאו רקע (URL מקובץ MP4)" },
        {
          "type": "select",
          "id": "card_size",
          "label": "גודל כרטיס",
          "options": [
            { "value": "card-standard", "label": "סטנדרטי (1/3)" },
            { "value": "card-wide", "label": "רחב (2/3)" }
          ],
          "default": "card-standard"
        },
        { "type": "header", "content": "מיקום טקסט" },
        { "type": "range", "id": "x_pos", "min": 0, "max": 100, "step": 5, "unit": "%", "label": "מיקום אופקי", "default": 50 },
        { "type": "range", "id": "y_pos", "min": 0, "max": 100, "step": 5, "unit": "%", "label": "מיקום אנכי", "default": 10 },
        {
          "type": "select",
          "id": "text_align",
          "label": "יישור טקסט",
          "options": [
            { "value": "right", "label": "ימין" },
            { "value": "center", "label": "מרכז" },
            { "value": "left", "label": "שמאל" }
          ],
          "default": "center"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DJI Feature Bento Grid",
      "blocks": [
        { "type": "feature_card", "settings": { "card_size": "card-wide", "title": "פונקציות תפעול חכמות" } },
        { "type": "feature_card", "settings": { "card_size": "card-standard", "title": "הצטיינות בסביבות תאורה חלשה" } },
        { "type": "feature_card", "settings": { "card_size": "card-standard", "title": "ראייה חדה ותמונות יציבות" } },
        { "type": "feature_card", "settings": { "card_size": "card-wide", "title": "מיפוי מדויק ביעילות גבוהה" } }
      ]
    }
  ]
}
{% endschema %}