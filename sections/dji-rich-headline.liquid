{%- comment -%}
  DJI Rich Headline Section - v1.1 (Fix: Range Limit 101 Steps)
  Optimized for Enterprise Shopify Stores - 2026
{%- endcomment -%}

{%- style -%}
  #DjiHeadline-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    direction: rtl;
    overflow: hidden;
  }

  .dji-headline-container-{{ section.id }} {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 4%;
    text-align: {{ section.settings.alignment }};
  }

  .dji-headline-content-{{ section.id }} * {
    margin: 0;
    color: inherit;
    font-family: inherit;
  }

  .dji-headline-content-{{ section.id }} p,
  .dji-headline-content-{{ section.id }} h1,
  .dji-headline-content-{{ section.id }} h2 {
    color: {{ section.settings.text_color }};
    font-family: 'Heebo', sans-serif;
    line-height: {{ section.settings.line_height }};
    letter-spacing: {{ section.settings.letter_spacing }}px;
    font-size: {{ section.settings.font_size_mobile }}px;
  }

  .dji-headline-content-{{ section.id }} strong,
  .dji-headline-content-{{ section.id }} b {
    font-weight: 800;
  }

  @media (min-width: 769px) {
    #DjiHeadline-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
    .dji-headline-content-{{ section.id }} p,
    .dji-headline-content-{{ section.id }} h1,
    .dji-headline-content-{{ section.id }} h2 {
      font-size: {{ section.settings.font_size_desktop }}px;
    }
  }

  @media (max-width: 768px) {
    .dji-headline-container-{{ section.id }} {
      padding-left: 16px;
      padding-right: 16px;
      box-sizing: border-box;
    }
  }
{%- endstyle -%}

<section id="DjiHeadline-{{ section.id }}" class="dji-rich-headline" {{ section.shopify_attributes }}>
  <div class="dji-headline-container-{{ section.id }}">
    {%- if section.settings.content != blank -%}
      <div class="dji-headline-content-{{ section.id }} richtext">
        {{ section.settings.content }}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "DJI Rich Headline",
  "settings": [
    {
      "type": "richtext",
      "id": "content",
      "label": "תוכן הכותרת",
      "default": "<p>Countless Applications, <strong>Two Models</strong></p>"
    },
    { "type": "range", "id": "container_width", "min": 600, "max": 1600, "step": 50, "unit": "px", "label": "רווח מיכל מקסימלי", "default": 1300 },
    {
      "type": "select",
      "id": "alignment",
      "label": "יישור טקסט",
      "options": [
        { "value": "right", "label": "ימין (RTL)" },
        { "value": "center", "label": "מרכז" },
        { "value": "left", "label": "שמאל" }
      ],
      "default": "center"
    },
    { "type": "header", "content": "🎨 צבעים" },
    { "type": "color", "id": "text_color", "label": "צבע טקסט", "default": "#ffffff" },
    { "type": "color", "id": "bg_color", "label": "צבע רקע", "default": "#000000" },
    { "type": "header", "content": "📏 טיפוגרפיה ומרווחים (דסקטופ)" },
    { 
      "type": "range", 
      "id": "font_size_desktop", 
      "min": 20, 
      "max": 120, 
      "step": 1, 
      "unit": "px", 
      "label": "גודל גופן דסקטופ", 
      "default": 56 
    },
    { "type": "range", "id": "padding_top_desktop", "min": 0, "max": 300, "step": 5, "unit": "px", "label": "רווח עליון דסקטופ", "default": 100 },
    { "type": "range", "id": "padding_bottom_desktop", "min": 0, "max": 300, "step": 5, "unit": "px", "label": "רווח תחתון דסקטופ", "default": 100 },
    { "type": "header", "content": "📱 טיפוגרפיה ומרווחים (מובייל)" },
    { "type": "range", "id": "font_size_mobile", "min": 12, "max": 80, "step": 1, "unit": "px", "label": "גודל גופן מובייל", "default": 32 },
    { "type": "range", "id": "padding_top_mobile", "min": 0, "max": 200, "step": 5, "unit": "px", "label": "רווח עליון מובייל", "default": 60 },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 200, "step": 5, "unit": "px", "label": "רווח תחתון מובייל", "default": 60 },
    { "type": "header", "content": "🔧 כיוונון עדין (Advanced)" },
    { "type": "range", "id": "line_height", "min": 1.0, "max": 2.0, "step": 0.1, "label": "גובה שורה (Line Height)", "default": 1.2 },
    { "type": "range", "id": "letter_spacing", "min": -5, "max": 10, "step": 1, "unit": "px", "label": "ריווח אותיות (Letter Spacing)", "default": -1 }
  ],
  "presets": [
    {
      "name": "DJI Rich Headline"
    }
  ]
}
{% endschema %}