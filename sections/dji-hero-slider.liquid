{%- style -%}
  .dji-hero-wrapper { position: relative; width: 100%; background: #000; overflow: hidden; }
  .dji-slider { display: flex; transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1); width: 100%; }
  .dji-slide { position: relative; flex: 0 0 100%; height: 85vh; display: flex; align-items: flex-start; justify-content: center; padding-top: 15vh; color: #fff; }
  .dji-media { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
  .dji-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.2); z-index: 1; }
  .dji-content { position: relative; z-index: 2; text-align: center; }
  .dji-nav { position: absolute; top: 50%; transform: translateY(-50%); z-index: 10; background: none; border: none; color: #fff; cursor: pointer; opacity: 0.5; transition: 0.3s; }
  .dji-nav:hover { opacity: 1; }
  .dji-nav svg { width: 30px; height: 60px; stroke-width: 1px; fill: none; stroke: currentColor; }
  .dji-prev { left: 20px; } .dji-next { right: 20px; }
{%- endstyle -%}

<section class="dji-hero-wrapper" id="Dji-{{ section.id }}">
  <div class="dji-slider" id="Container-{{ section.id }}">
    {% for block in section.blocks %}
      <div class="dji-slide" {{ block.shopify_attributes }}>
        {% if block.settings.video_url != blank %}
          <video autoplay muted loop playsinline class="dji-media"><source src="{{ block.settings.video_url }}" type="video/mp4"></video>
        {% elsif block.settings.image != blank %}
          <img src="{{ block.settings.image | image_url: width: 2500 }}" class="dji-media">
        {% endif %}
        <div class="dji-overlay"></div>
        <div class="dji-content">
          <h2 style="font-size: 4rem; margin: 0;">{{ block.settings.title }}</h2>
          <p>{{ block.settings.subtitle }}</p>
        </div>
      </div>
    {% endfor %}
  </div>
  <button class="dji-nav dji-prev" onclick="moveDji(-1, '{{ section.id }}')"><svg viewBox="0 0 10 20"><polyline points="9 1 1 10 9 19"></polyline></svg></button>
  <button class="dji-nav dji-next" onclick="moveDji(1, '{{ section.id }}')"><svg viewBox="0 0 10 20"><polyline points="1 1 9 10 1 19"></polyline></svg></button>
</section>

<script>
  let djiCounter = 0;
  function moveDji(dir, id) {
    const cont = document.getElementById('Container-' + id);
    const slides = cont.querySelectorAll('.dji-slide');
    djiCounter = (djiCounter + dir + slides.length) % slides.length;
    cont.style.transform = `translateX(-${djiCounter * 100}%)`;
  }
</script>

{% schema %}
{
  "name": "DJI Global Hero Slider",
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "video_url", "label": "Video URL" },
        { "type": "text", "id": "title", "label": "Title", "default": "DJI PRODUCT" },
        { "type": "text", "id": "subtitle", "label": "Subtitle" }
      ]
    }
  ],
  "presets": [{"name": "DJI Global Hero Slider"}]
}
{% endschema %}