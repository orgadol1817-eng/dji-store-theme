<article class="article-template" dir="rtl" style="background-color: #000; color: #fff; padding: 60px 20px;">
  <div style="max-width: 800px; margin: 0 auto;">
    <h1 style="font-family: 'Heebo', sans-serif;">{{ article.title }}</h1>
    <div style="font-family: 'Heebo', sans-serif; line-height: 1.6;">{{ article.content }}</div>
  </div>
</article>

{% schema %}
{
  "name": "Article Content",
  "settings": [],
  "presets": [{ "name": "Default Article" }]
}
{% endschema %}