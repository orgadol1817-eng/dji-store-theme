{% stylesheet %}
/* =====================================================
   DJI Bento Grid — product showcase cards
   Mirrors the minimalist product grid on dji.com/global
   ===================================================== */

.bento-grid-section {
  width: 100%;
  padding: 60px 0;
  background: #fff;
}

.bento-grid__heading {
  text-align: center;
  font-size: clamp(1.4rem, 2.5vw, 2rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  margin-bottom: 40px;
  color: #111;
}

/* ---- Grid container ---- */
.bento-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px;
}

/* ---- Card shell ---- */
.bento-card {
  position: relative;
  background: #f7f7f7;
  border-radius: 8px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
}

/* ---- Image wrapper — clips the scale transform ---- */
.bento-card__img-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 10;
  overflow: hidden;
  background: #e8e8e8;
  flex-shrink: 0;
}

.bento-card__picture {
  display: block;
  width: 100%;
  height: 100%;
}

.bento-card__img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  will-change: transform;
}

.bento-card:hover .bento-card__img {
  transform: scale(1.03);
}

/* ---- Text area ---- */
.bento-card__body {
  padding: 24px 28px 28px;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.bento-card__label {
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  margin-bottom: 8px;
  opacity: 0.6;
}

.bento-card__title {
  font-size: clamp(1.3rem, 2.2vw, 1.75rem);
  font-weight: 700;
  line-height: 1.15;
  margin-bottom: 8px;
  letter-spacing: -0.02em;
}

.bento-card__subtitle {
  font-size: 0.9rem;
  font-weight: 300;
  line-height: 1.55;
  opacity: 0.75;
  margin-bottom: 22px;
  flex: 1;
}

/* ---- CTA row ---- */
.bento-card__actions {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  align-items: center;
}

.bento-card__cta {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 0.88rem;
  font-weight: 500;
  text-decoration: none;
  transition: opacity 0.2s ease;
}

.bento-card__cta:hover {
  opacity: 0.65;
}

.bento-card__cta--learn {
  color: inherit;
  border-bottom: 1px solid currentColor;
  padding-bottom: 1px;
}

.bento-card__cta--buy {
  padding: 7px 22px;
  border-radius: 50px;
  border: 1.5px solid currentColor;
  background: transparent;
}

.bento-card__cta--buy:hover {
  opacity: 1;
  background: currentColor;
}

.bento-card__cta--buy:hover span {
  mix-blend-mode: difference;
  color: #fff;
}

/* ---- Text color variants ---- */
.bento-card--dark .bento-card__body {
  color: #111111;
}

.bento-card--light .bento-card__body {
  color: #ffffff;
}

.bento-card--light {
  background: #1a1a1a;
}

/* ---- Placeholder (no image uploaded) ---- */
.bento-card__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e0e0e0;
}

.bento-card__placeholder svg {
  width: 80px;
  height: 80px;
  opacity: 0.25;
}

/* ---- Responsive ---- */
@media (max-width: 768px) {
  .bento-grid {
    grid-template-columns: 1fr;
    padding: 0 16px;
    gap: 14px;
  }

  .bento-grid-section {
    padding: 40px 0;
  }

  .bento-card__body {
    padding: 18px 20px 22px;
  }

  .bento-card__img-wrap {
    aspect-ratio: 4 / 3;
  }
}

/* ---- 2-col mobile option ---- */
.bento-grid--mobile-2 {
  grid-template-columns: repeat(2, 1fr);
}
{% endstylesheet %}

{%- assign grid_mobile_class = '' -%}
{%- if section.settings.columns_mobile == '2' -%}
  {%- assign grid_mobile_class = 'bento-grid--mobile-2' -%}
{%- endif -%}

<div class="bento-grid-section">
  {%- if section.settings.section_title != blank -%}
    <h2 class="bento-grid__heading">{{ section.settings.section_title }}</h2>
  {%- endif -%}

  <div class="bento-grid {{ grid_mobile_class }}">
    {%- for block in section.blocks -%}
      {%- assign color_class = 'bento-card--dark' -%}
      {%- if block.settings.text_color == 'light' -%}
        {%- assign color_class = 'bento-card--light' -%}
      {%- endif -%}

      <article class="bento-card {{ color_class }}" {{ block.shopify_attributes }}>

        <!-- ── Image ── -->
        <div class="bento-card__img-wrap">
          {%- if block.settings.image != blank -%}
            <picture class="bento-card__picture">
              {%- if block.settings.image_mobile != blank -%}
                <source
                  media="(max-width: 768px)"
                  srcset="{{ block.settings.image_mobile | image_url: width: 750 }}">
              {%- else -%}
                <source
                  media="(max-width: 768px)"
                  srcset="{{ block.settings.image | image_url: width: 750 }}">
              {%- endif -%}
              <img
                src="{{ block.settings.image | image_url: width: 1200 }}"
                alt="{{ block.settings.title | escape }}"
                class="bento-card__img"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                loading="lazy">
            </picture>
          {%- else -%}
            <div class="bento-card__placeholder">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {%- endif -%}
        </div>

        <!-- ── Body ── -->
        <div class="bento-card__body">
          {%- if block.settings.label != blank -%}
            <p class="bento-card__label">{{ block.settings.label }}</p>
          {%- endif -%}

          <h3 class="bento-card__title">{{ block.settings.title }}</h3>

          {%- if block.settings.subtitle != blank -%}
            <p class="bento-card__subtitle">{{ block.settings.subtitle }}</p>
          {%- else -%}
            <p class="bento-card__subtitle"></p>
          {%- endif -%}

          <div class="bento-card__actions">
            {%- if block.settings.link_learn != blank -%}
              <a
                href="{{ block.settings.link_learn }}"
                class="bento-card__cta bento-card__cta--learn"
                aria-label="{{ 'sections.bento_grid.learn_more' | t }}: {{ block.settings.title | escape }}">
                {{ 'sections.bento_grid.learn_more' | t }}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {%- endif -%}

            {%- if block.settings.link_buy != blank -%}
              <a
                href="{{ block.settings.link_buy }}"
                class="bento-card__cta bento-card__cta--buy"
                aria-label="{{ 'sections.bento_grid.buy_now' | t }}: {{ block.settings.title | escape }}">
                <span>{{ 'sections.bento_grid.buy_now' | t }}</span>
              </a>
            {%- endif -%}
          </div>
        </div>

      </article>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Bento Grid",
  "tag": "section",
  "class": "dji-bento-grid-section",
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Mobile image (optional)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "info": "Small uppercase tag above the title (e.g. NEW, Enterprise)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "DJI Product"
        },
        {
          "type": "textarea",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Inspiration in Focus"
        },
        {
          "type": "header",
          "content": "Call-to-action links"
        },
        {
          "type": "url",
          "id": "link_learn",
          "label": "Learn more link"
        },
        {
          "type": "url",
          "id": "link_buy",
          "label": "Buy now link"
        },
        {
          "type": "header",
          "content": "Style"
        },
        {
          "type": "select",
          "id": "text_color",
          "label": "Text color",
          "options": [
            { "value": "dark",  "label": "Dark (on light background)" },
            { "value": "light", "label": "Light (on dark background)" }
          ],
          "default": "dark"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section heading",
      "info": "Optional heading displayed above the grid"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ],
      "default": "1"
    }
  ],
  "presets": [
    {
      "name": "Bento Grid",
      "blocks": [
        {
          "type": "product_card",
          "settings": {
            "label": "NEW",
            "title": "DJI Air 3S",
            "subtitle": "Chase the View",
            "text_color": "dark"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "label": "Enterprise",
            "title": "DJI Matrice 400",
            "subtitle": "Engineered for Excellence, Designed for Versatility",
            "text_color": "dark"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "label": "HANDHELD",
            "title": "DJI RS 5",
            "subtitle": "Lead the Scene",
            "text_color": "dark"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "label": "ACTION",
            "title": "Osmo Action 6",
            "subtitle": "Square Up, Nail the Move",
            "text_color": "dark"
          }
        }
      ]
    }
  ]
}
{% endschema %}
