{%- comment -%}
  DJI Specs Comparison - v6.0 "The Architect Masterpiece"
  Author: AI Senior Architect
  Logic: Precise XY Positioning + Full Typography Engine + Frame Control
{%- endcomment -%}

{%- style -%}
  :root {
    --specs-x-pos: {{ section.settings.horizontal_pos }}%;
    --specs-y-pos: {{ section.settings.vertical_pos }}%;
    
    /* מנוע גדלי טקסט */
    --model-font-size: {{ section.settings.model_font_size }}px;
    --cat-font-size: {{ section.settings.cat_font_size }}px;
    --details-font-size: {{ section.settings.details_font_size }}px;
  }

  .dji-specs-v6-wrapper {
    position: relative;
    width: 100%;
    /* שליטה בגובה הכללי למניעת חיתוך */
    height: {{ section.settings.section_height_desktop }}vh;
    min-height: 600px;
    background-color: {{ section.settings.bg_main }};
    overflow: hidden;
    font-family: 'Heebo', sans-serif;
    color: #ffffff;
    direction: rtl;
  }

  /* קונטיינר מרכזי - המיקום שלו בתוך השחור */
  .dji-specs-v6-content {
    position: absolute;
    top: var(--specs-y-pos);
    left: var(--specs-x-pos);
    transform: translate(-50%, -50%);
    width: 90%;
    max-width: {{ section.settings.content_max_width }}px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    z-index: 10;
  }

  /* עיצוב הכרטיס (המסגרת) */
  .dji-card-v6 {
    background-color: {{ section.settings.bg_card }};
    /* שליטה ברווח הפנימי להגדלת המסגרת */
    padding: {{ section.settings.card_padding }}px;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6), inset 0 1px 1px rgba(255,255,255,0.02);
    position: relative;
    overflow: hidden;
    text-align: right;
  }

  /* אפקט ה-Rim Light המקצועי */
  .dji-card-v6::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    z-index: 5;
  }

  .glow-thermal::before {
    background: linear-gradient(90deg, transparent, {{ section.settings.glow_1 }} 70%, {{ section.settings.glow_1 }});
  }

  .glow-optical::before {
    background: linear-gradient(90deg, transparent, {{ section.settings.glow_2 }} 70%, {{ section.settings.glow_2 }});
  }

  /* עיצוב טקסט דינמי */
  .model-name-v6 {
    font-size: var(--model-font-size);
    font-weight: 700;
    margin-bottom: 40px;
    color: {{ section.settings.color_model_name }};
    text-transform: uppercase;
  }

  .spec-group-v6 {
    margin-bottom: 30px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    padding-bottom: 15px;
  }

  .cat-title-v6 {
    font-size: var(--cat-font-size);
    font-weight: 600;
    margin-bottom: 8px;
    color: {{ section.settings.color_cat }};
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .cat-title-v6 sup { font-size: 0.6em; opacity: 0.5; }

  .details-text-v6 {
    font-size: var(--details-font-size);
    line-height: 1.6;
    color: {{ section.settings.color_details }};
    font-weight: 300;
  }

  .not-available { color: rgba(255,255,255,0.15); font-style: italic; }

  @media (max-width: 1024px) {
    .dji-specs-v6-wrapper { height: auto; padding: 100px 0; }
    .dji-specs-v6-content { 
      position: relative; top: 0; left: 0; transform: none; 
      grid-template-columns: 1fr; margin: 0 auto;
    }
    .dji-card-v6 { padding: 40px 25px; }
  }
{%- endstyle -%}

<section class="dji-specs-v6-wrapper">
  <div class="dji-specs-v6-content">
    
    <div class="dji-card-v6 glow-thermal">
      <h3 class="model-name-v6">{{ section.settings.model_1_name }}</h3>
      
      <div class="spec-group-v6">
        <div class="cat-title-v6">מצלמה רחבה<sup>[2]</sup></div>
        <div class="details-text-v6">حיישן 1/1.3" CMOS, 48MP פיקסלים אפקטיביים, מפתח צמצם f/1.7, אורך מוקד שווה ערך ל-24 מ"מ.</div>
      </div>

      <div class="spec-group-v6">
        <div class="cat-title-v6">מצלמת טלה בינונית<sup>[3]</sup></div>
        <div class="details-text-v6">حיישן 1/1.3" CMOS, 48MP פיקסלים אפקטיביים, מפתח צמצם f/2.8, אורך מוקד שווה ערך ל-70 מ"מ.</div>
      </div>

      <div class="spec-group-v6">
        <div class="cat-title-v6">מצלמת טלה<sup>[3]</sup></div>
        <div class="details-text-v6">حיישן 1/1.5" CMOS, 48MP פיקסלים אפקטיביים, מפתח צמצם f/2.8, אורך מוקד שווה ערך ל-168 מ"מ.</div>
      </div>

      <div class="spec-group-v6">
        <div class="cat-title-v6">מד טווח לייזר</div>
        <div class="details-text-v6">טווח מדידה: 1800 מטר (1 הרץ); טווח זווית אלכסונית: 600 מטר. דיוק טווח: ± (0.2 + 0.0015 × D).</div>
      </div>

      <div class="spec-group-v6">
        <div class="cat-title-v6">מצלמה תרמית אינפרה-אדום</div>
        <div class="details-text-v6">רזולוציה: 640×512, מפתח צמצם f/1.0, אורך מוקד שווה ערך ל-53 מ"מ, מיקרו-בולומטר VOx לא מקורר.</div>
      </div>

      <div class="spec-group-v6">
        <div class="cat-title-v6">תאורת עזר NIR</div>
        <div class="details-text-v6">שדה ראייה (FOV): 6°, מרחק תאורה: 100 מטר.</div>
      </div>
    </div>

    <div class="dji-card-v6 glow-optical">
      <h3 class="model-name-v6">{{ section.settings.model_2_name }}</h3>
      
      <div class="spec-group-v6">
        <div class="cat-title-v6">מצלמה רחבה<sup>[1]</sup></div>
        <div class="details-text-v6">حיישן 4/3 CMOS, 20MP פיקסלים אפקטיביים, מפתח צמצם f/2.8-f/11, אורך מוקד 24 מ"מ, <strong>תריס מכני</strong>.</div>
      </div>

      <div class="spec-group-v6">
        <div class="cat-title-v6">מצלמת טלה בינונית<sup>[3]</sup></div>
        <div class="details-text-v6">حיישן 1/1.3" CMOS, 48MP פיקסלים אפקטיביים, מפתח צמצם f/2.8, אורך מוקד שווה ערך ל-70 מ"מ.</div>
      </div>

      <div class="spec-group-v6">
        <div class="cat-title-v6">מצלמת טלה<sup>[3]</sup></div>
        <div class="details-text-v6">حיישן 1/1.5" CMOS, 48MP פיקסלים אפקטיביים, מפתח צמצם f/2.8, אורך מוקד שווה ערך ל-168 מ"מ.</div>
      </div>

      <div class="spec-group-v6">
        <div class="cat-title-v6">מד טווח לייזר</div>
        <div class="details-text-v6">טווח מדידה: 1800 מטר (1 הרץ); טווח זווית אלכסונית: 600 מטר. דיוק טווח: ± (0.2 + 0.0015 × D).</div>
      </div>

      <div class="spec-group-v6">
        <div class="cat-title-v6">מצלמה תרמית אינפרה-אדום</div>
        <div class="details-text-v6 not-available">לא זמין בדגם זה</div>
      </div>

      <div class="spec-group-v6">
        <div class="cat-title-v6">תאורת עזר NIR</div>
        <div class="details-text-v6 not-available">לא זמין בדגם זה</div>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "DJI Specs Comparison",
  "settings": [
    { "type": "header", "content": "מיקום וגאומטריה (Layout)" },
    { "type": "range", "id": "section_height_desktop", "min": 50, "max": 150, "step": 5, "unit": "vh", "label": "גובה הסקשן", "default": 100 },
    { "type": "range", "id": "horizontal_pos", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "מיקום אופקי (X)", "default": 50 },
    { "type": "range", "id": "vertical_pos", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "מיקום אנכי (Y)", "default": 50 },
    { "type": "range", "id": "content_max_width", "min": 800, "max": 1600, "step": 50, "unit": "px", "label": "רוחב מקסימלי לגריד", "default": 1300 },
    { "type": "range", "id": "card_padding", "min": 20, "max": 120, "step": 5, "unit": "px", "label": "גודל המסגרת הפנימית (Padding)", "default": 70 },
    
    { "type": "header", "content": "מנוע טקסט (Typography)" },
    { "type": "range", "id": "model_font_size", "min": 20, "max": 60, "step": 1, "unit": "px", "label": "גודל שם דגם", "default": 34 },
    { "type": "range", "id": "cat_font_size", "min": 14, "max": 24, "step": 1, "unit": "px", "label": "גודל קטגוריה", "default": 17 },
    { "type": "range", "id": "details_font_size", "min": 12, "max": 20, "step": 1, "unit": "px", "label": "גודל פירוט טכני", "default": 15 },
    
    { "type": "header", "content": "צבעים (Colors)" },
    { "type": "color", "id": "bg_main", "label": "צבע רקע דף", "default": "#000000" },
    { "type": "color", "id": "bg_card", "label": "צבע רקע כרטיס", "default": "#161616" },
    { "type": "color", "id": "color_model_name", "label": "צבע שם דגם", "default": "#ffffff" },
    { "type": "color", "id": "color_cat", "label": "צבע קטגוריה", "default": "#ffffff" },
    { "type": "color", "id": "color_details", "label": "צבע פירוט טכני", "default": "rgba(255,255,255,0.65)" },
    { "type": "color", "id": "glow_1", "label": "צבע זוהר דגם 1 (Thermal)", "default": "#ff9a00" },
    { "type": "color", "id": "glow_2", "label": "צבע זוהר דגם 2 (Optical)", "default": "#00d4ff" },
    
    { "type": "header", "content": "טקסטים" },
    { "type": "text", "id": "model_1_name", "label": "שם דגם 1", "default": "DJI MATRICE 4T" },
    { "type": "text", "id": "model_2_name", "label": "שם דגם 2", "default": "DJI MATRICE 4E" }
  ],
  "presets": [{ "name": "DJI Specs Comparison" }]
}
{% endschema %}