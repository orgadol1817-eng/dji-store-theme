{%- comment -%}
  DJI Global Hero Ultimate - v11.0 (The Final Architect + Loop Control)
  - Hybrid Video Engine: YouTube (No-UI) + MP4
  - Loop Control: Option to enable/disable infinite loop
  - 3-Layer Typography: Pre-title, Thin Title, Bold Sub-title
  - DJI Professional Pill-Button with Modal Lightbox
  - Full XY Positioning Control
{%- endcomment -%}

{%- style -%}
  :root {
    --dji-hero-h-desktop: {{ section.settings.section_height_desktop }}vh;
    --dji-hero-h-mobile: {{ section.settings.section_height_mobile }}vh;
    --content-x: {{ section.settings.horizontal_pos }}%;
    --content-y: {{ section.settings.vertical_pos }}%;
  }

  .dji-hero-master {
    position: relative;
    width: 100%;
    height: var(--dji-hero-h-desktop);
    min-height: 550px;
    background-color: #000;
    overflow: hidden;
    font-family: 'Heebo', sans-serif;
  }

  /* מנוע מדיה - רקע */
  .dji-hero-media-engine {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .dji-hero-media-engine iframe, 
  .dji-hero-media-engine video {
    width: 100vw;
    height: 56.25vw;
    min-height: 100vh;
    min-width: 177.77vh;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    object-fit: cover;
    border: none;
  }

  .dji-hero-v11-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: {{ section.settings.overlay_gradient }};
  }

  /* קופסת תוכן - XY Positioning */
  .dji-hero-v11-content {
    position: absolute;
    top: var(--content-y);
    left: var(--content-x);
    transform: translate(-50%, -50%);
    z-index: 10;
    width: 100%;
    max-width: 1100px;
    padding: 20px;
    text-align: {{ section.settings.text_alignment }};
    pointer-events: none;
  }

  .dji-hero-v11-content * { pointer-events: auto; }

  /* טיפוגרפיה DJI Enterprise */
  .dji-pre-title {
    font-size: clamp(14px, 1.2vw, 18px);
    font-weight: 300;
    color: {{ section.settings.color_pre_title }} !important;
    margin-bottom: 8px;
    letter-spacing: 0.5px;
    opacity: 0.8;
  }

  .dji-main-title {
    font-size: clamp(40px, 8vw, {{ section.settings.title_size }}px);
    font-weight: 300; 
    line-height: 1;
    margin: 0;
    letter-spacing: -1.5px;
    text-transform: uppercase;
    color: {{ section.settings.color_title }} !important;
  }

  .dji-bold-subtitle {
    font-size: clamp(20px, 2.5vw, 32px);
    font-weight: 700; 
    margin: 15px 0 35px;
    color: {{ section.settings.color_sub }} !important;
  }

  /* כפתור Watch Video (Pill Style) */
  .dji-v11-actions {
    display: flex;
    justify-content: {{ section.settings.text_alignment | replace: 'left', 'flex-start' | replace: 'right', 'flex-end' }};
  }

  .dji-v11-btn-watch {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.5);
    color: {{ section.settings.color_btn_text }} !important;
    padding: 10px 35px;
    border-radius: 50px;
    font-size: 16px;
    font-weight: 400;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .dji-v11-btn-watch:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: #fff;
    transform: translateY(-2px);
  }

  .dji-v11-play-icon {
    width: 0;
    height: 0;
    border-top: 6px solid transparent;
    border-bottom: 6px solid transparent;
    border-left: 10px solid currentColor;
    margin-left: 4px;
  }

  /* Modal System */
  .dji-v11-modal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.95);
    z-index: 100000;
    align-items: center; justify-content: center;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .dji-v11-modal.is-active { display: flex; opacity: 1; }
  .dji-v11-modal-content {
    width: 90%;
    max-width: 1100px;
    aspect-ratio: 16 / 9;
    position: relative;
    background: #000;
    border-radius: 8px;
    overflow: hidden;
  }
  .dji-v11-modal-media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
  .dji-v11-modal-content video.dji-v11-modal-media {
    object-fit: contain;
    background: #000;
  }
  .dji-v11-modal-close {
    position: absolute; top: -50px; right: 0;
    background: none; border: none; color: #fff; font-size: 45px; cursor: pointer;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .dji-hero-master { height: var(--dji-hero-h-mobile); }
    .dji-hero-v11-content {
      top: 50% !important;
      left: 50% !important;
      text-align: center;
      padding-left: 16px;
      padding-right: 16px;
      box-sizing: border-box;
    }
    .dji-v11-actions { justify-content: center; }
  }
{%- endstyle -%}

{%- liquid
  assign modal_watch = section.settings.watch_url | strip
  assign modal_is_youtube = false
  assign modal_yt_id = ''
  if modal_watch != blank
    if modal_watch contains 'youtube.com' or modal_watch contains 'youtu.be'
      assign modal_is_youtube = true
    endif
  endif
  if modal_is_youtube
    if modal_watch contains 'youtu.be/'
      assign modal_yt_id = modal_watch | split: 'youtu.be/' | last | split: '?' | first | split: '/' | first
    elsif modal_watch contains 'youtube.com/embed/'
      assign modal_yt_id = modal_watch | split: 'embed/' | last | split: '?' | first
    elsif modal_watch contains '/shorts/'
      assign modal_yt_id = modal_watch | split: '/shorts/' | last | split: '?' | first | split: '/' | first
    elsif modal_watch contains 'v='
      assign modal_yt_id = modal_watch | split: 'v=' | last | split: '&' | first | split: '#' | first
    endif
  endif
-%}

<div class="dji-hero-master">
  <div class="dji-hero-v11-overlay"></div>
  
  <div class="dji-hero-media-engine">
    {%- if section.settings.video_type == 'youtube' -%}
      {%- assign yt_id = section.settings.bg_video_url | split: 'v=' | last | split: '&' | first -%}
      {%- assign loop_val = 0 -%}
      {%- assign loop_playlist = "" -%}
      {%- if section.settings.enable_loop -%}
        {%- assign loop_val = 1 -%}
        {%- assign loop_playlist = "&playlist=" | append: yt_id -%}
      {%- endif -%}
      <iframe 
        src="https://www.youtube.com/embed/{{ yt_id }}?autoplay=1&mute=1&loop={{ loop_val }}{{ loop_playlist }}&controls=0&showinfo=0&rel=0&iv_load_policy=3&enablejsapi=1" 
        allow="autoplay; encrypted-media" 
        allowfullscreen>
      </iframe>
    {%- else -%}
      {%- if section.settings.bg_video_url != blank -%}
        <video autoplay muted {% if section.settings.enable_loop %}loop{% endif %} playsinline preload="auto">
          <source src="{{ section.settings.bg_video_url }}" type="video/mp4">
        </video>
      {%- endif -%}
    {%- endif -%}
  </div>

  <div class="dji-hero-v11-content">
    <p class="dji-pre-title">{{ section.settings.pre_headline }}</p>
    <h1 class="dji-main-title">{{ section.settings.headline }}</h1>
    <p class="dji-bold-subtitle">{{ section.settings.sub_headline }}</p>
    
    <div class="dji-v11-actions">
      {%- if modal_watch != blank -%}
        <button type="button" class="dji-v11-btn-watch" data-v11-open="{{ section.id }}">
          <span>{{ section.settings.watch_label }}</span>
          <div class="dji-v11-play-icon"></div>
        </button>
      {%- endif -%}
    </div>
  </div>
</div>

<div class="dji-v11-modal" id="V11Modal-{{ section.id }}" role="dialog" aria-modal="true" aria-label="{{ section.settings.watch_label | escape }}">
  <div class="dji-v11-modal-content">
    <button type="button" class="dji-v11-modal-close" aria-label="Close">&times;</button>
    {%- if modal_watch != blank -%}
      {%- if modal_is_youtube and modal_yt_id != blank -%}
        <iframe
          id="V11Iframe-{{ section.id }}"
          class="dji-v11-modal-media"
          title="{{ section.settings.watch_label | escape }}"
          width="560"
          height="315"
          src="about:blank"
          data-youtube-id="{{ modal_yt_id | escape }}"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
          loading="lazy"
        ></iframe>
      {%- elsif modal_is_youtube == false -%}
        <video
          id="V11Player-{{ section.id }}"
          class="dji-v11-modal-media"
          controls
          playsinline
          preload="metadata"
        >
          <source src="{{ modal_watch | escape }}" type="video/mp4">
        </video>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>

<script>
  (function () {
    var sectionId = '{{ section.id }}';
    var modal = document.getElementById('V11Modal-' + sectionId);
    if (!modal) return;

    var openBtns = document.querySelectorAll('[data-v11-open="' + sectionId + '"]');
    var closeBtn = modal.querySelector('.dji-v11-modal-close');
    var video = modal.querySelector('video.dji-v11-modal-media');
    var iframe = modal.querySelector('iframe.dji-v11-modal-media');

    function stopPlayback() {
      if (video) {
        video.pause();
        video.currentTime = 0;
      }
      if (iframe) {
        iframe.src = 'about:blank';
      }
    }

    function openModal() {
      modal.classList.add('is-active');
      if (iframe) {
        var yid = iframe.getAttribute('data-youtube-id');
        if (yid) {
          iframe.src =
            'https://www.youtube.com/embed/' +
            encodeURIComponent(yid) +
            '?autoplay=1&rel=0&modestbranding=1&playsinline=1';
        }
      }
      if (video) {
        video.play().catch(function () {});
      }
    }

    function closeModal() {
      modal.classList.remove('is-active');
      stopPlayback();
    }

    openBtns.forEach(function (btn) {
      btn.addEventListener('click', openModal);
    });
    if (closeBtn) closeBtn.addEventListener('click', closeModal);

    modal.addEventListener('click', function (e) {
      if (e.target === modal) closeModal();
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && modal.classList.contains('is-active')) closeModal();
    });
  })();
</script>

{% schema %}
{
  "name": "DJI Global Hero Ultimate",
  "settings": [
    {
      "type": "select",
      "id": "video_type",
      "label": "סוג וידאו רקע",
      "options": [
        { "value": "mp4", "label": "קובץ MP4" },
        { "value": "youtube", "label": "יוטיוב" }
      ],
      "default": "mp4"
    },
    { "type": "text", "id": "bg_video_url", "label": "קישור לוידאו רקע" },
    { "type": "checkbox", "id": "enable_loop", "label": "נגן ב-LOOP (לופ אינסופי)", "default": true },
    { "type": "text", "id": "watch_url", "label": "קישור וידאו לצפייה (מודאל)" },
    { "type": "text", "id": "watch_label", "label": "טקסט כפתור", "default": "Watch Video" },
    { "type": "header", "content": "טקסטים (DJI Style)" },
    { "type": "text", "id": "pre_headline", "label": "כותרת גג קטנה", "default": "Flagship Intelligent Multi-Sensor Compact Drone" },
    { "type": "text", "id": "headline", "label": "כותרת ראשית", "default": "DJI MATRICE 4 SERIES" },
    { "type": "text", "id": "sub_headline", "label": "תת כותרת", "default": "The Age of Intelligent Flight" },
    { "type": "range", "id": "title_size", "min": 30, "max": 120, "step": 1, "unit": "px", "label": "גודל כותרת", "default": 85 },
    { "type": "header", "content": "צבעים" },
    { "type": "color", "id": "color_pre_title", "label": "צבע כותרת גג", "default": "#ffffff" },
    { "type": "color", "id": "color_title", "label": "צבע כותרת ראשית", "default": "#ffffff" },
    { "type": "color", "id": "color_sub", "label": "צבע תת כותרת", "default": "#ffffff" },
    { "type": "color", "id": "color_btn_text", "label": "צבע טקסט כפתור", "default": "#ffffff" },
    { "type": "color_background", "id": "overlay_gradient", "label": "שכבת הצללה", "default": "linear-gradient(180deg, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0) 50%, rgba(0,0,0,0.4) 100%)" },
    { "type": "header", "content": "מיקום מדויק (XY Positioning)" },
    { "type": "range", "id": "horizontal_pos", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "מיקום אופקי (X)", "default": 50 },
    { "type": "range", "id": "vertical_pos", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "מיקום אנכי (Y)", "default": 50 },
    { "type": "select", "id": "text_alignment", "label": "יישור טקסט", "options": [
      {"value": "left", "label": "שמאל"},
      {"value": "center", "label": "מרכז"},
      {"value": "right", "label": "ימין"}
    ], "default": "center" },
    { "type": "range", "id": "section_height_desktop", "min": 50, "max": 100, "step": 5, "unit": "vh", "label": "גובה דסקטופ", "default": 100 },
    { "type": "range", "id": "section_height_mobile", "min": 50, "max": 100, "step": 5, "unit": "vh", "label": "גובה מובייל", "default": 90 }
  ],
  "presets": [{ "name": "DJI Global Hero Ultimate" }]
}
{% endschema %}