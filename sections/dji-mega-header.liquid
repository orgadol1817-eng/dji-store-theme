{% # theme-check-disable RemoteAsset %}
<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;700&display=swap" rel="stylesheet">
{% # theme-check-enable RemoteAsset %}

{%- style -%}
  .dji-header {
    background: {{ section.settings.bg_color }};
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
    direction: rtl;
    font-family: 'Heebo', sans-serif;
    position: relative;
    z-index: 1000;
    color: #fff;
  }

  .dji-header__container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
    min-height: 70px;
    position: relative;
  }

  .dji-mega-burger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 4px;
    background: transparent;
    color: #fff;
    cursor: pointer;
    flex-shrink: 0;
  }

  .dji-mega-burger svg {
    width: 22px;
    height: 22px;
  }

  .dji-logo {
    text-decoration: none;
    color: inherit;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .dji-logo-img {
    max-height: 45px;
    width: auto;
    display: block;
  }

  .dji-header__nav {
    display: flex;
    gap: 30px;
    align-items: center;
    height: 100%;
    flex: 1;
    justify-content: center;
  }

  .dji-nav__link {
    text-decoration: none;
    color: #fff;
    font-weight: 500;
    font-size: 15px;
    cursor: pointer;
    min-height: 44px;
    display: flex;
    align-items: center;
  }

  .dji-mega-wrapper {
    position: relative;
    height: 100%;
    display: flex;
    align-items: center;
  }

  .dji-mega-menu {
    position: absolute;
    top: 70px;
    right: -100px;
    width: 100vw;
    background: #0a0a0a;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    z-index: 1100;
    padding: 40px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .dji-mega-wrapper:hover .dji-mega-menu {
    opacity: 1;
    visibility: visible;
  }

  .dji-mega-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    max-width: 1200px;
    margin: 0 auto;
    gap: 25px;
    padding: 0 20px;
  }

  .dji-mega-item {
    text-align: center;
    text-decoration: none;
    color: #fff;
    transition: transform 0.3s;
  }

  .dji-mega-item:hover {
    transform: translateY(-5px);
  }

  .dji-mega-item img {
    width: 70px;
    height: 70px;
    object-fit: contain;
    margin-bottom: 12px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 50%;
    padding: 10px;
  }

  .dji-header__tools {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .dji-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    color: #fff;
    text-decoration: none;
    border: 1px solid transparent;
    border-radius: 4px;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .dji-icon-btn:hover {
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.05);
  }

  .dji-icon-btn svg {
    width: 22px;
    height: 22px;
    stroke: currentColor;
    fill: none;
  }

  /* Mobile drawer + overlay */
  .dji-mega-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    z-index: 1190;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    pointer-events: none;
  }

  .dji-mega-overlay.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .dji-mega-drawer {
    position: fixed;
    top: 0;
    right: 0;
    width: min(100%, 360px);
    height: 100%;
    background: #000;
    border-left: 1px solid rgba(255, 255, 255, 0.18);
    z-index: 1200;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    pointer-events: none;
    visibility: hidden;
  }

  .dji-mega-drawer.is-open {
    transform: translateX(0);
    pointer-events: auto;
    visibility: visible;
  }

  .dji-mega-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 18px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    flex-shrink: 0;
  }

  .dji-mega-drawer__title {
    font-size: 15px;
    font-weight: 700;
    color: #fff;
  }

  .dji-mega-drawer__close {
    min-width: 44px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 4px;
    color: #fff;
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    padding: 0;
  }

  .dji-mega-drawer__nav {
    display: flex;
    flex-direction: column;
    padding: 8px 0 24px;
  }

  .dji-mega-drawer__link {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    min-height: 48px;
    padding: 12px 20px;
    color: #fff;
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .dji-mega-drawer__link:active {
    background: rgba(255, 255, 255, 0.06);
  }

  .dji-mega-drawer__sub {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.55);
    font-weight: 400;
    margin-top: 2px;
  }

  @media (max-width: 768px) {
    .dji-header__nav {
      display: none !important;
    }

    .dji-mega-burger {
      display: flex;
      order: 3;
    }

    .dji-logo {
      order: 2;
      flex: 1 1 auto;
      justify-content: center;
    }

    .dji-header__tools {
      order: 1;
    }

    .dji-header__container {
      padding: 0 16px;
      justify-content: space-between;
    }
  }
{%- endstyle -%}

<header class="dji-header" data-dji-mega-header="{{ section.id }}">
  <div class="dji-header__container">
    <button
      type="button"
      class="dji-mega-burger"
      id="dji-mega-burger-{{ section.id }}"
      aria-expanded="false"
      aria-controls="dji-mega-drawer-{{ section.id }}"
      aria-label="תפריט"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path stroke="currentColor" stroke-width="1.8" stroke-linecap="round" d="M5 7h14M5 12h14M5 17h14"/>
      </svg>
    </button>

    <a href="{{ routes.root_url }}" class="dji-logo">
      {% if section.settings.logo != blank %}
        {{ section.settings.logo | image_url: width: 300 | image_tag: class: 'dji-logo-img', alt: shop.name, loading: 'eager' }}
      {% else %}
        <span style="font-weight:700;font-size:22px;">{{ shop.name }}</span>
      {% endif %}
    </a>

    <nav class="dji-header__nav" aria-label="{{ section.settings.mega_title | escape }}">
      <div class="dji-mega-wrapper">
        <span class="dji-nav__link">{{ section.settings.mega_title }}</span>
        <div class="dji-mega-menu">
          <div class="dji-mega-grid">
            {%- for block in section.blocks -%}
              <a href="{{ block.settings.link }}" class="dji-mega-item" {{ block.shopify_attributes }}>
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 140, height: 140, crop: 'center' | image_tag: width: 70, height: 70, loading: 'lazy', style: 'border-radius:50%;object-fit:contain;background:rgba(255,255,255,0.06);padding:10px;margin-bottom:12px;' }}
                {% else %}
                  <div style="width:70px;height:70px;background:rgba(255,255,255,0.08);border-radius:50%;margin:0 auto 12px;"></div>
                {% endif %}
                <div style="font-weight:700;font-size:16px;">{{ block.settings.title }}</div>
                <div style="font-size:12px;color:rgba(255,255,255,0.55);">{{ block.settings.subtitle }}</div>
              </a>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </nav>

    <div class="dji-header__tools">
      <a href="{{ routes.search_url }}" class="dji-icon-btn" aria-label="חיפוש">
        <svg viewBox="0 0 24 24" aria-hidden="true" stroke="currentColor"><circle cx="11" cy="11" r="7" stroke-width="1.8" fill="none"/><path d="M16.5 16.5L22 22" stroke-width="1.8" stroke-linecap="round" fill="none"/></svg>
      </a>
      <a href="{{ routes.cart_url }}" class="dji-icon-btn" aria-label="עגלה">
        <svg viewBox="0 0 24 24" aria-hidden="true" stroke="currentColor" fill="none"><path stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><path d="M3 6h18" stroke-width="1.8"/><path d="M16 10a4 4 0 01-8 0" stroke-width="1.8"/></svg>
      </a>
    </div>
  </div>
</header>

<div
  class="dji-mega-overlay"
  id="dji-mega-overlay-{{ section.id }}"
  data-dji-mega-overlay
  aria-hidden="true"
></div>

<div
  class="dji-mega-drawer"
  id="dji-mega-drawer-{{ section.id }}"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-labelledby="dji-mega-drawer-title-{{ section.id }}"
>
  <div class="dji-mega-drawer__header">
    <span class="dji-mega-drawer__title" id="dji-mega-drawer-title-{{ section.id }}">{{ section.settings.mega_title }}</span>
    <button type="button" class="dji-mega-drawer__close" data-dji-mega-close aria-label="סגור">×</button>
  </div>
  <nav class="dji-mega-drawer__nav" aria-label="{{ section.settings.mega_title | escape }}">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link }}" class="dji-mega-drawer__link" {{ block.shopify_attributes }}>
        <span>
          {{ block.settings.title }}
          {% if block.settings.subtitle != blank %}
            <span class="dji-mega-drawer__sub">{{ block.settings.subtitle }}</span>
          {% endif %}
        </span>
      </a>
    {%- endfor -%}
  </nav>
</div>

<script>
(function () {
  var id = '{{ section.id }}';
  var burger = document.getElementById('dji-mega-burger-' + id);
  var drawer = document.getElementById('dji-mega-drawer-' + id);
  var overlay = document.getElementById('dji-mega-overlay-' + id);
  if (!burger || !drawer || !overlay) return;

  function openMenu() {
    drawer.classList.add('is-open');
    overlay.classList.add('is-open');
    drawer.setAttribute('aria-hidden', 'false');
    overlay.setAttribute('aria-hidden', 'false');
    burger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    drawer.classList.remove('is-open');
    overlay.classList.remove('is-open');
    drawer.setAttribute('aria-hidden', 'true');
    overlay.setAttribute('aria-hidden', 'true');
    burger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  burger.addEventListener('click', function (e) {
    e.preventDefault();
    if (drawer.classList.contains('is-open')) closeMenu();
    else openMenu();
  });

  overlay.addEventListener('click', closeMenu);

  var closeBtn = drawer.querySelector('[data-dji-mega-close]');
  if (closeBtn) closeBtn.addEventListener('click', closeMenu);

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && drawer.classList.contains('is-open')) closeMenu();
  });

  drawer.querySelectorAll('.dji-mega-drawer__link').forEach(function (link) {
    link.addEventListener('click', function () {
      closeMenu();
    });
  });
})();
</script>

{% schema %}
{
  "name": "DJI Mega Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#000000" },
    { "type": "text", "id": "mega_title", "label": "Menu Title", "default": "רחפנים מקצועיים" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Icon" },
        { "type": "text", "id": "title", "label": "Title", "default": "חקלאות" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "פתרונות ריסוס" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  },
  "presets": [
    { "name": "DJI Mega Header" }
  ]
}
{% endschema %}
