    { "type": "header", "content": "🎨 עיצוב טקסט גלובלי" },
    { "type": "range", "id": "column_title_size", "min": 16, "max": 50, "step": 1, "unit": "px", "label": "גודל כותרת פנימית", "default": 28 },
    { "type": "color", "id": "color_column_title", "label": "צבע כותרת פנימית", "default": "#ffffff" },
    { "type": "range", "id": "column_desc_size", "min": 12, "max": 30, "step": 1, "unit": "px", "label": "גודל טקסט תיאור", "default": 16 },
    { "type": "color", "id": "color_column_desc", "label": "צבע טקסט תיאור", "default": "rgba(255,255,255,0.7)" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 200, "step": 5, "unit": "px", "label": "רווח עליון", "default": 100 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 200, "step": 5, "unit": "px", "label": "רווח תחתון", "default": 100 }
  ],
  "blocks": [
    {
      "type": "feature_column",
