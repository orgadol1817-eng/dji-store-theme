    { "type": "range", "id": "grid_gap", "min": 0, "max": 100, "step": 2, "unit": "px", "label": "רווח בין כרטיסים", "default": 40 },
    { "type": "range", "id": "card_radius", "min": 0, "max": 40, "step": 1, "unit": "px", "label": "עיגול פינות מסגרת (לכל הכרטיס)", "default": 12 },
    { "type": "text", "id": "media_aspect_ratio", "label": "יחס גובה-רוחב (16/9, 4/3)", "default": "4/3" },
