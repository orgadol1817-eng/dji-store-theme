{%- style -%}
  #shopify-section-{{ section.id }} {
    --intro-bg: {{ section.settings.bg_color }};
    --intro-x-pos: {{ section.settings.horizontal_pos }}%;
    --intro-y-pos: {{ section.settings.vertical_pos }}%;
    --content-max-width: {{ section.settings.content_max_width }}px;
  }

  .dji-intro-v3 {
    position: relative;
    background-color: var(--intro-bg);
    width: 100%;
    height: {{ section.settings.section_height }}px;
    min-height: 300px;
    overflow: hidden;
    font-family: 'Heebo', sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dji-intro-content-wrapper {
    position: absolute;
    top: var(--intro-y-pos);
    left: var(--intro-x-pos);
    transform: translate(-50%, -50%);
    width: 90%;
    max-width: var(--content-max-width);
    padding: 20px;
    text-align: {{ section.settings.text_alignment }};
    direction: rtl;
  }

  /* טקסט הקדמה (קטן) */
  .dji-intro-paragraph {
    color: {{ section.settings.intro_color }};
    font-size: {{ section.settings.intro_size }}px;
    font-weight: {{ section.settings.intro_weight }};
    line-height: 1.6;
    margin-bottom: {{ section.settings.intro_margin_bottom }}px;
  }

  /* כותרת מודגשת (Accent) */
  .dji-heading-accent {
    color: {{ section.settings.accent_color }} !important;
    display: block;
    font-size: {{ section.settings.accent_size }}px;
    font-weight: {{ section.settings.accent_weight }};
    line-height: {{ section.settings.heading_line_height }};
    text-transform: uppercase;
    letter-spacing: -1px;
  }

  /* כותרת דקה (Main) */
  .dji-heading-main {
    color: {{ section.settings.main_text_color }} !important;
    font-size: {{ section.settings.main_text_size }}px;
    font-weight: {{ section.settings.main_text_weight }};
    line-height: {{ section.settings.heading_line_height }};
    display: block;
    text-transform: uppercase;
  }

  /* התאמות למובייל */
  @media (max-width: 768px) {
    .dji-intro-v3 {
      height: auto !important;
      padding: 60px 16px;
      min-height: auto;
      box-sizing: border-box;
    }
    .dji-intro-content-wrapper {
      position: relative !important;
      top: 0 !important;
      left: 0 !important;
      transform: none !important;
      margin: 0 auto;
      text-align: center;
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
    }
    .dji-intro-paragraph {
      font-size: {{ section.settings.intro_size_mobile }}px;
    }
    .dji-heading-accent {
      font-size: {{ section.settings.accent_size_mobile }}px;
    }
    .dji-heading-main {
      font-size: {{ section.settings.main_text_size_mobile }}px;
    }
  }
{%- endstyle -%}

<div class="dji-intro-v3">
  <div class="dji-intro-content-wrapper">
    {%- if section.settings.intro_text != blank -%}
      <div class="dji-intro-paragraph">
        {{ section.settings.intro_text }}
      </div>
    {%- endif -%}

    <h2 class="dji-intro-heading">
      <span class="dji-heading-accent">{{ section.settings.accent_text }}</span>
      <span class="dji-heading-main">{{ section.settings.main_text }}</span>
    </h2>
  </div>
</div>

{% schema %}
{
  "name": "DJI Product Intro Text",
  "settings": [
    {
      "type": "header",
      "content": "Global Settings (כללי)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "צבע רקע",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "section_height",
      "min": 200,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "label": "גובה הסקשן (דסקטופ)",
      "default": 500
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 400,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "label": "רוחב תוכן מקסימלי",
      "default": 1000
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "יישור טקסט",
      "options": [
        { "value": "left", "label": "שמאל" },
        { "value": "center", "label": "מרכז" },
        { "value": "right", "label": "ימין" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Intro Paragraph (טקסט עליון קטן)"
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "תוכן הטקסט",
      "default": "<p>Introducing the DJI Matrice 4 Series, a new multi-sensor flagship drone.</p>"
    },
    {
      "type": "color",
      "id": "intro_color",
      "label": "צבע טקסט",
      "default": "#cccccc"
    },
    {
      "type": "range",
      "id": "intro_size",
      "min": 12,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "גודל גופן",
      "default": 18
    },
    {
      "type": "range",
      "id": "intro_size_mobile",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "גודל גופן (מובייל)",
      "default": 15
    },
    {
      "type": "select",
      "id": "intro_weight",
      "label": "עובי גופן",
      "options": [
        { "value": "300", "label": "דק" },
        { "value": "400", "label": "רגיל" },
        { "value": "700", "label": "מודגש" }
      ],
      "default": "300"
    },
    {
      "type": "range",
      "id": "intro_margin_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "רווח מתחת לטקסט",
      "default": 30
    },
    {
      "type": "header",
      "content": "Accent Heading (החלק הצבעוני)"
    },
    {
      "type": "text",
      "id": "accent_text",
      "label": "טקסט",
      "default": "Two Models,"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "צבע",
      "default": "#0070d5"
    },
    {
      "type": "range",
      "id": "accent_size",
      "min": 20,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "גודל גופן",
      "default": 74
    },
    {
      "type": "range",
      "id": "accent_size_mobile",
      "min": 15,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "גודל גופן (מובייל)",
      "default": 40
    },
    {
      "type": "select",
      "id": "accent_weight",
      "label": "עובי גופן",
      "options": [
        { "value": "400", "label": "רגיל" },
        { "value": "700", "label": "מודגש" },
        { "value": "900", "label": "סופר מודגש" }
      ],
      "default": "900"
    },
    {
      "type": "header",
      "content": "Main Heading (החלק הלבן)"
    },
    {
      "type": "text",
      "id": "main_text",
      "label": "טקסט",
      "default": "Countless Applications"
    },
    {
      "type": "color",
      "id": "main_text_color",
      "label": "צבע",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "main_text_size",
      "min": 20,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "גודל גופן",
      "default": 70
    },
    {
      "type": "range",
      "id": "main_text_size_mobile",
      "min": 15,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "גודל גופן (מובייל)",
      "default": 38
    },
    {
      "type": "select",
      "id": "main_text_weight",
      "label": "עובי גופן",
      "options": [
        { "value": "100", "label": "דק מאוד" },
        { "value": "300", "label": "דק" },
        { "value": "400", "label": "רגיל" }
      ],
      "default": "300"
    },
    {
      "type": "text",
      "id": "heading_line_height",
      "label": "מרווח בין שורות הכותרת",
      "default": "1.1"
    },
    {
      "type": "header",
      "content": "Positioning (מיקום XY)"
    },
    {
      "type": "range",
      "id": "horizontal_pos",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "מיקום אופקי (X)",
      "default": 50
    },
    {
      "type": "range",
      "id": "vertical_pos",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "מיקום אנכי (Y)",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "DJI Product Intro Text"
    }
  ]
}
{% endschema %}