{% stylesheet %}
/* ── DROX top bar ── */
.drox-top-bar { position: relative; width: 100%; z-index: 2; font-family: 'Heebo', sans-serif; direction: rtl; box-sizing: border-box; }
.drox-top-bar__inner { max-width: 1400px; margin: 0 auto; padding: 0 3%; box-sizing: border-box; display: flex; flex-direction: row; direction: rtl; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; }
.drox-top-bar__col { flex: 1 1 0; min-width: 0; text-align: center; }
.drox-top-bar__col--links { text-align: right; }
.drox-top-bar__col--phone { text-align: left; }
.drox-top-bar__link { color: inherit; text-decoration: none; font-size: 12px; font-weight: 500; transition: opacity 0.2s ease; }
.drox-top-bar__link:hover { opacity: 0.85; text-decoration: underline; }
.drox-top-bar__link--static { cursor: default; }
.drox-top-bar__link--static:hover { opacity: 1; text-decoration: none; }
.drox-top-bar__links-row { display: flex; flex-wrap: wrap; align-items: center; justify-content: flex-start; gap: var(--drox-links-gap, 8px); width: 100%; }
.drox-top-bar__pipe { opacity: 0.65; font-weight: 400; user-select: none; }
.drox-top-bar__segment { will-change: transform; }
.drox-top-bar__promo { font-size: 12px; font-weight: 500; line-height: 1.4; }
.drox-top-bar__contact-line { display: inline-block; font-size: 12px; line-height: 1.4; }
.drox-top-bar__left-label { font-weight: 500; }
.drox-top-bar__phone-num { font-weight: 600; }
@media (max-width: 768px) {
  .drox-top-bar__inner { flex-direction: column; justify-content: center; gap: 8px; padding-left: 4%; padding-right: 4%; }
  .drox-top-bar__col--links, .drox-top-bar__col--phone { text-align: center; }
}
@media (max-width: 767px) {
  .drox-top-bar__inner { flex-direction: row; flex-wrap: wrap; justify-content: center; align-items: center; align-content: center; gap: 10px; row-gap: 8px; }
  .drox-top-bar__col { flex: 1 1 auto; min-width: 0; max-width: 100%; }
  .drox-top-bar__col--links { text-align: center; }
  .drox-top-bar__links-row { justify-content: center; }
}

/* ── Site Header (height set in section style settings — header_height) ── */
.site-header { position: sticky; top: 0; left: 0; right: 0; width: 100%; min-height: 60px; z-index: 9000; background: transparent; transition: background 0.35s ease, backdrop-filter 0.35s ease, box-shadow 0.35s ease; font-family: 'Heebo', sans-serif; direction: rtl; overflow: visible; margin: 0; padding: 0; }
.site-header.scrolled { background: rgba(255, 255, 255, 0.92); backdrop-filter: blur(15px); box-shadow: 0 1px 0 rgba(0,0,0,0.08); }
.sh-inner { display: flex; align-items: center; justify-content: space-between; height: 100%; max-width: 1400px; margin: 0 auto; padding: 0 3%; overflow: visible; }
.sh-logo { display: flex; align-items: center; flex-shrink: 0; justify-content: center; }
.header__logo-img { transition: filter 0.25s ease; }
.sh-nav { display: flex; align-items: center; flex-wrap: nowrap; gap: 2px; height: 100%; overflow: visible; margin: 0; }
.sh-mega-wrap { position: relative; display: flex; align-items: stretch; height: 100%; z-index: 9601; }
.sh-mega-trigger { display: flex; align-items: center; height: 100%; cursor: pointer; }
.sh-nav__item { position: relative; display: flex; align-items: center; height: 100%; }
.sh-nav__item--license { display: flex; align-items: center; height: 100%; }
.sh-nav__link--license { position: relative; display: inline-flex; align-items: center; justify-content: center; }
.sh-nav__link--license .sh-nav__badge { position: absolute; top: -14px; left: 50%; transform: translateX(-50%); font-size: 10px; font-weight: 700; line-height: 1.2; padding: 3px 8px; border-radius: 4px; white-space: nowrap; pointer-events: none; box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2); }
.sh-nav__link { display: flex; align-items: center; height: 100%; padding: 0 16px; font-size: 15px; font-weight: 500; text-decoration: none; transition: color 0.25s ease, opacity 0.25s ease; white-space: nowrap; position: relative; }
.sh-nav__link--mega { display: inline-flex; align-items: center; gap: 6px; }
.sh-nav__mega-chevron { flex-shrink: 0; transition: transform 0.25s ease; }
.sh-mega-wrap:hover .sh-nav__mega-chevron { transform: rotate(180deg); }
.sh-tools { display: flex; align-items: center; gap: 4px; }
.sh-tool-btn { display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border: none; background: transparent; cursor: pointer; border-radius: 50%; transition: color 0.25s ease, background 0.25s ease; position: relative; text-decoration: none; }
.sh-tool-btn:hover { background: rgba(128,128,128,0.12); }
.sh-cart-count { position: absolute; top: 4px; left: 4px; background: #0070d5; color: #fff; font-size: 10px; font-weight: 700; width: 16px; height: 16px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'Heebo', sans-serif; }
.sh-hamburger { flex-direction: column; gap: 4px; display: none; }
.sh-hamburger span { display: block; width: 20px; height: 2px; background: currentColor; border-radius: 2px; transition: all 0.3s ease; }

/* Drawer & Search Panels */
.sh-search-panel { position: fixed; top: 0; left: 0; right: 0; width: 100%; background: #fff; z-index: 10050; transform: translateY(-110%); visibility: hidden; transition: transform 0.55s, visibility 0.55s; box-shadow: 0 6px 20px rgba(0,0,0,0.1); }
.sh-search-panel.is-open { transform: translateY(0); visibility: visible; }
.sh-search-panel__inner { display: flex; align-items: center; max-width: 860px; margin: 0 auto; padding: 18px 5%; gap: 12px; direction: rtl; }
.sh-search-form { display: flex; flex: 1; align-items: center; border-bottom: 2px solid #1a1a1a; gap: 8px; }
.sh-search-input { flex: 1; border: none; outline: none; font-size: 18px; padding: 8px 4px; background: transparent; direction: rtl; }
.sh-search-submit, .sh-search-close { border: none; background: transparent; cursor: pointer; color: #1a1a1a; padding: 8px; display: flex; align-items: center; }

.sh-drawer-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 9050; opacity: 0; transition: opacity 0.3s ease; }
.sh-drawer-overlay.is-open { opacity: 1; }
.sh-drawer { position: fixed; top: 0; right: -320px; width: 300px; max-width: 90vw; height: 100%; background: var(--sh-drawer-bg); color: var(--sh-drawer-text); z-index: 9100; overflow-y: auto; transition: right 0.35s; direction: rtl; font-family: 'Heebo', sans-serif; }
.sh-drawer.is-open { right: 0; }
.sh-drawer__header { display: flex; align-items: center; justify-content: space-between; padding: 20px; border-bottom: 1px solid rgba(255,255,255,0.1); }
.sh-drawer__logo { font-size: 20px; font-weight: 800; letter-spacing: 2px; }
.sh-drawer__close { border: none; background: transparent; cursor: pointer; color: inherit; padding: 4px; display: flex; }
.sh-drawer__links { list-style: none; margin: 0; padding: 16px 0; }
.sh-drawer__link { display: block; padding: 14px 20px; font-size: 16px; font-weight: 500; color: inherit; text-decoration: none; }
.sh-drawer__link--with-badge { position: relative; padding-top: 26px; }
.sh-drawer__badge { position: absolute; top: 8px; right: 20px; font-size: 11px; font-weight: 700; padding: 3px 8px; border-radius: 4px; background: var(--sh-license-badge-bg); color: var(--sh-license-badge-fg); }
.sh-drawer__sub summary { cursor: pointer; list-style: none; }
.sh-drawer__sub summary::-webkit-details-marker { display: none; }
.sh-drawer__mega-body { padding: 0 0 8px; }
.sh-drawer__mega-l2 { margin: 0; padding: 12px 20px 4px; font-size: 14px; font-weight: 600; opacity: 0.9; cursor: pointer; }
.sh-drawer__sub-links { list-style: none; padding: 0 20px 0 0; margin: 0; }
.sh-drawer__sub-links li a { display: block; padding: 10px 20px; font-size: 14px; color: var(--sh-drawer-accent); text-decoration: none; }

@media (max-width: 768px) {
  .sh-nav { display: none; }
  .sh-hamburger { display: flex; }
  .sh-inner { padding: 0 5%; }
}
@media (min-width: 769px) {
  .sh-hamburger { display: none; }
  .sh-drawer { display: none; }
}
{% endstylesheet %}

{% javascript %}
(function () {
  var header = document.getElementById('site-header');
  if (header) {
    window.addEventListener('scroll', function () {
      header.classList.toggle('scrolled', window.scrollY > 5);
    }, { passive: true });
  }

  var searchBtn = document.getElementById('sh-search-btn');
  var searchPanel = document.getElementById('sh-search-panel');
  var searchClose = document.getElementById('sh-search-close');
  var searchInput = document.getElementById('sh-search-input');
  
  function openSearch() {
    if (!searchPanel) return;
    searchPanel.classList.add('is-open');
    searchPanel.setAttribute('aria-hidden', 'false');
    setTimeout(function () { if (searchInput) searchInput.focus(); }, 80);
  }
  function closeSearch() {
    if (!searchPanel) return;
    searchPanel.classList.remove('is-open');
    searchPanel.setAttribute('aria-hidden', 'true');
  }
  if (searchBtn) searchBtn.addEventListener('click', function (e) { e.stopPropagation(); openSearch(); });
  if (searchClose) searchClose.addEventListener('click', closeSearch);

  var hamburger = document.getElementById('sh-hamburger');
  var drawer = document.getElementById('sh-drawer');
  var overlay = document.getElementById('sh-drawer-overlay');
  var drawerClose = document.getElementById('sh-drawer-close');

  function openDrawer() {
    if (!drawer) return;
    drawer.classList.add('is-open');
    if (overlay) { overlay.style.display = 'block'; requestAnimationFrame(function () { overlay.classList.add('is-open'); }); }
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer() {
    if (!drawer) return;
    drawer.classList.remove('is-open');
    if (overlay) { overlay.classList.remove('is-open'); setTimeout(function () { overlay.style.display = 'none'; }, 350); }
    document.body.style.overflow = '';
  }
  if (hamburger) hamburger.addEventListener('click', openDrawer);
  if (drawerClose) drawerClose.addEventListener('click', closeDrawer);
  if (overlay) overlay.addEventListener('click', closeDrawer);

  var droxTopBar = document.querySelector('[data-drox-top-bar]');
  function syncDroxTopBarOffset() {
    var siteHeader = document.getElementById('site-header');
    if (!siteHeader) return;
    if (!droxTopBar) {
      document.documentElement.style.removeProperty('--drox-top-offset');
      return;
    }
    var bottom = droxTopBar.getBoundingClientRect().bottom;
    if (bottom <= 0) {
      siteHeader.classList.remove('site-header--has-top-bar');
      document.documentElement.style.removeProperty('--drox-top-offset');
    } else {
      siteHeader.classList.add('site-header--has-top-bar');
      document.documentElement.style.setProperty('--drox-top-offset', Math.round(bottom) + 'px');
    }
  }
  window.addEventListener('scroll', syncDroxTopBarOffset, { passive: true });
  window.addEventListener('resize', syncDroxTopBarOffset);
  if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', syncDroxTopBarOffset); } 
  else { syncDroxTopBarOffset(); }
})();
{% endjavascript %}

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "header", "content": "Top bar (announcement)" },
    { "type": "checkbox", "id": "show_top_bar", "label": "Show top bar", "default": true },
    { "type": "color", "id": "top_bar_bg", "label": "Top bar background", "default": "#000000" },
    { "type": "color", "id": "top_bar_right_color", "label": "Right column — link text", "default": "#ffffff" },
    { "type": "color", "id": "top_bar_middle_color", "label": "Middle — promo text", "default": "#ffffff" },
    { "type": "color", "id": "top_bar_left_label_color", "label": "Left — contact label", "default": "#ffffff" },
    { "type": "color", "id": "top_bar_phone_color", "label": "Left — phone number", "default": "#ff9a00" },
    { "type": "range", "id": "top_bar_links_gap", "min": 4, "max": 20, "step": 1, "unit": "px", "label": "Right column — space between links", "default": 8 },
    { "type": "range", "id": "right_segment_offset", "min": -100, "max": 100, "step": 2, "unit": "px", "label": "Right column — horizontal nudge", "default": 0 },
    { "type": "range", "id": "middle_segment_offset", "min": -100, "max": 100, "step": 2, "unit": "px", "label": "Middle — horizontal nudge", "default": 0 },
    { "type": "range", "id": "left_segment_offset", "min": -100, "max": 100, "step": 2, "unit": "px", "label": "Left column — horizontal nudge", "default": 0 },
    { "type": "url", "id": "about_link", "label": "About (אודות)" },
    { "type": "text", "id": "about_link_label", "label": "About link label", "default": "אודות" },
    { "type": "url", "id": "terms_link", "label": "Terms of use (תקנון האתר)" },
    { "type": "text", "id": "terms_link_label", "label": "Terms link label", "default": "תקנון האתר" },
    { "type": "url", "id": "privacy_link", "label": "Privacy policy (מדיניות פרטיות)" },
    { "type": "text", "id": "privacy_link_label", "label": "Privacy link label", "default": "מדיניות פרטיות" },
    { "type": "text", "id": "promo_text", "label": "Promo text (center)", "default": "הזמינו רחפן וקבלו הדרכת הטסה חינם" },
    { "type": "text", "id": "left_contact_label", "label": "Left — contact label", "default": "להזמנות או פרטים חייגו עכשיו: " },
    { "type": "text", "id": "phone_number_text", "label": "Left — phone number", "default": "03-656-5500" },
    { "type": "range", "id": "top_bar_height", "min": 28, "max": 56, "step": 2, "unit": "px", "label": "Top bar height / padding", "default": 36 },
    { "type": "header", "content": "Top bar — mobile" },
    { "type": "checkbox", "id": "show_top_bar_mobile", "label": "Show top bar on mobile", "default": true },
    { "type": "checkbox", "id": "hide_links_mobile", "label": "Hide right column (links) on mobile", "default": false },
