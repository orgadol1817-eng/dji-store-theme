                             {%- if block.settings.link_2_text != blank -%}<li><a href="{{ block.settings.link_2_url | default: '#' }}">{{ block.settings.link_2_text }}</a></li>{%- endif -%}
                             {%- if block.settings.link_3_text != blank -%}<li><a href="{{ block.settings.link_3_url | default: '#' }}">{{ block.settings.link_3_text }}</a></li>{%- endif -%}
                             {%- if block.settings.link_4_text != blank -%}<li><a href="{{ block.settings.link_4_url | default: '#' }}">{{ block.settings.link_4_text }}</a></li>{%- endif -%}
                             {%- if block.settings.link_5_text != blank -%}<li><a href="{{ block.settings.link_5_url | default: '#' }}">{{ block.settings.link_5_text }}</a></li>{%- endif -%}
                             {%- if block.settings.link_6_text != blank -%}<li><a href="{{ block.settings.link_6_url | default: '#' }}">{{ block.settings.link_6_text }}</a></li>{%- endif -%}
                             {%- if block.settings.link_7_text != blank -%}<li><a href="{{ block.settings.link_7_url | default: '#' }}">{{ block.settings.link_7_text }}</a></li>{%- endif -%}
                             {%- if block.settings.link_8_text != blank -%}<li><a href="{{ block.settings.link_8_url | default: '#' }}">{{ block.settings.link_8_text }}</a></li>{%- endif -%}
